---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");

// Collect all tags and count them
const tagCounts = allPosts.reduce((acc, post) => {
	const tags = post.data.tags || [];
	tags.forEach((tag) => {
		acc[tag] = (acc[tag] || 0) + 1;
	});
	return acc;
}, {} as Record<string, number>);

// Sort tags alphabetically
const sortedTags = Object.entries(tagCounts).sort((a, b) => 
	a[0].localeCompare(b[0])
);
---

<Layout
	title="Tags - Appsecmonarch Blog"
	description="Jelajahi artikel berdasarkan topik dan tags"
>
	<section class="py-12 md:py-20 px-6 md:px-12 max-w-7xl mx-auto">
		<div class="max-w-3xl mb-12 md:mb-16">
			<h1
				class="text-4xl md:text-6xl font-serif font-bold text-gray-900 mb-6 leading-tight"
			>
				Jelajahi <span class="text-primary italic">Tags</span>
			</h1>
			<p
				class="text-xl md:text-2xl text-gray-600 leading-relaxed font-serif"
			>
				Temukan artikel berdasarkan topik yang Anda minati. Klik pada tag untuk melihat semua artikel terkait.
			</p>
		</div>

		<div class="flex flex-wrap gap-4">
			{
				sortedTags.map(([tag, count]) => (
					<a
						href={`/tags/${tag}`}
						class="group flex items-center gap-2 px-5 py-3 bg-white border-2 border-gray-200 rounded-lg hover:border-primary hover:bg-primary/5 transition-all duration-300"
					>
						<span class="text-lg font-serif font-medium text-gray-900 group-hover:text-primary transition-colors">
							#{tag}
						</span>
						<span class="flex items-center justify-center min-w-[28px] h-7 px-2 bg-gray-100 group-hover:bg-primary group-hover:text-white rounded-full text-sm font-semibold text-gray-700 transition-all">
							{count}
						</span>
					</a>
				))
			}
		</div>

		{sortedTags.length === 0 && (
			<div class="text-center py-12">
				<p class="text-gray-500 text-lg">Belum ada tags tersedia.</p>
			</div>
		)}
	</section>
</Layout>
