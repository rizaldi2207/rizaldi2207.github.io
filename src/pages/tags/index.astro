---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");

const tagCounts = allPosts.reduce((acc, post) => {
    const tags = post.data.tags || [];
    tags.forEach((tag) => {
        acc[tag] = (acc[tag] || 0) + 1;
    });
    return acc;
}, {} as Record<string, number>);

const sortedTags = Object.entries(tagCounts).sort((a, b) =>
    a[0].localeCompare(b[0])
);
---

<Layout
    title="Tags — Appsecmonarch"
    description="Jelajahi artikel berdasarkan topik dan tags."
>
    <section class="tags-section">
        <div class="tags-header fade-in-up">
            <div class="code-label">// EXPLORE_TAGS</div>
            <h1 class="tags-heading">
                Jelajahi <em class="em-accent">Tags</em>
            </h1>
            <p class="tags-sub">
                Temukan artikel berdasarkan topik yang kamu minati.
            </p>
        </div>

        {sortedTags.length > 0 ? (
            <div class="tags-grid fade-in-up">
                {sortedTags.map(([tag, count]) => (
                    <a href={`/tags/${tag}`} class="tag-card">
                        <span class="tag-name">#{tag}</span>
                        <span class="tag-count">{count}</span>
                    </a>
                ))}
            </div>
        ) : (
            <p class="empty-msg">Belum ada tags tersedia.</p>
        )}
    </section>
</Layout>

<style>
    .tags-section {
        max-width: 1280px;
        margin: 0 auto;
        padding: 4rem 2.5rem 8rem;
    }
    @media (max-width: 640px) { .tags-section { padding: 3rem 1.5rem 6rem; } }

    .code-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        color: #00d4ff;
        letter-spacing: 0.1em;
        opacity: 0.7;
        margin-bottom: 1rem;
    }

    .tags-heading {
        font-family: "IBM Plex Serif", serif;
        font-weight: 700;
        font-size: clamp(2.5rem, 5vw, 3.75rem);
        line-height: 1.1;
        color: var(--text);
        margin-bottom: 1.25rem;
    }

    .em-accent { font-style: italic; color: #00d4ff; }
    html:not(.dark) .em-accent { color: #003377; }

    .tags-sub {
        font-size: 1.0625rem;
        color: var(--text-muted);
        max-width: 480px;
        line-height: 1.7;
        margin-bottom: 3rem;
    }

    .tags-header { margin-bottom: 3rem; }

    /* Tags grid */
    .tags-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.875rem;
    }

    .tag-card {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.5rem 1rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s ease;
    }
    .tag-card:hover {
        border-color: #00d4ff;
        background: rgba(0, 212, 255, 0.06);
    }
    html:not(.dark) .tag-card:hover {
        border-color: #003377;
        background: rgba(0, 51, 119, 0.06);
    }

    .tag-name {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.875rem;
        color: var(--text);
        transition: color 0.2s;
    }
    .tag-card:hover .tag-name { color: #00d4ff; }
    html:not(.dark) .tag-card:hover .tag-name { color: #003377; }

    .tag-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 22px;
        height: 22px;
        padding: 0 6px;
        background: rgba(0, 212, 255, 0.1);
        color: #00d4ff;
        border-radius: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        font-weight: 600;
        transition: all 0.2s;
    }
    html:not(.dark) .tag-count {
        background: rgba(0, 51, 119, 0.08);
        color: #003377;
    }
    .tag-card:hover .tag-count {
        background: #00d4ff;
        color: #0a0e1a;
    }
    html:not(.dark) .tag-card:hover .tag-count {
        background: #003377;
        color: #fff;
    }

    .empty-msg {
        font-size: 1rem;
        color: var(--text-muted);
    }
</style>

<script>
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
