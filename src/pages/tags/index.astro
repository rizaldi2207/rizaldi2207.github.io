---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");

const tagCounts = allPosts.reduce((acc, post) => {
    (post.data.tags ?? []).forEach((tag) => {
        acc[tag] = (acc[tag] || 0) + 1;
    });
    return acc;
}, {} as Record<string, number>);

// Busiest topics first, then alphabetical — a flat A–Z buries the ones with
// the most to read.
const sortedTags = Object.entries(tagCounts).sort(
    (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);
---

<Layout
    title="Topik — Appsecmonarch"
    description="Jelajahi tulisan berdasarkan topik yang kamu minati."
>
    <section class="tags-hero">
        <div class="tags-hero-inner">
            <p class="eyebrow">Topik</p>
            <h1 class="hero-heading">Jelajahi berdasarkan topik</h1>
            <p class="hero-sub">
                Temukan tulisan sesuai yang sedang kamu pelajari hari ini.
            </p>
        </div>
    </section>

    <section class="tags-body fade-in-up">
        {sortedTags.length > 0 ? (
            <div class="tags-grid">
                {sortedTags.map(([tag, count]) => (
                    <a href={`/tags/${tag}`} class="tag-card">
                        <span class="tag-name">{tag}</span>
                        <span class="tag-count">{count}</span>
                    </a>
                ))}
            </div>
        ) : (
            <div class="empty-state">
                <p class="empty-title">Belum ada topik.</p>
                <p class="empty-sub">Tag akan muncul di sini setelah ada tulisan.</p>
            </div>
        )}
    </section>
</Layout>

<style>
    .tags-hero {
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
    }
    .tags-hero-inner { max-width: 1180px; margin: 0 auto; padding: 72px 40px 60px; }
    @media (max-width: 640px) { .tags-hero-inner { padding: 48px 24px 40px; } }

    .hero-heading {
        font-size: clamp(2rem, 5vw, 48px);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 18px;
    }
    .hero-sub { font-size: 17px; color: var(--text-muted); line-height: 1.7; max-width: 640px; }

    .tags-body { max-width: 1180px; margin: 0 auto; padding: 56px 40px 96px; }
    @media (max-width: 640px) { .tags-body { padding: 40px 24px 64px; } }

    .tags-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 16px;
    }

    .tag-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px 22px;
        text-decoration: none;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }
    .tag-card:hover {
        border-color: #b8d3ef;
        box-shadow: var(--shadow-card);
        transform: translateY(-2px);
    }
    html.dark .tag-card:hover { border-color: var(--accent); }

    .tag-name {
        font-family: Syne, sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.01em;
        transition: color 0.2s;
    }
    .tag-card:hover .tag-name { color: var(--accent); }

    .tag-count {
        font-size: 12px;
        font-weight: 600;
        color: var(--accent);
        background: var(--accent-soft);
        border-radius: 6px;
        padding: 3px 9px;
        flex-shrink: 0;
    }

    .empty-state { text-align: center; padding: 4rem 0; }
    .empty-title {
        font-family: Syne, sans-serif;
        font-size: 1.125rem; font-weight: 700;
        color: var(--text); margin-bottom: 0.5rem;
    }
    .empty-sub { font-size: 0.9375rem; color: var(--text-muted); }
</style>

<script>
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
