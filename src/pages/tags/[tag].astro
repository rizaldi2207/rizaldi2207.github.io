---
import Layout from "../../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
    const allPosts = await getCollection("blog");
    const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))];

    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts.filter((post) =>
            post.data.tags?.includes(tag)
        );
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

interface Props {
    posts: CollectionEntry<"blog">[];
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
    title={`#${tag} — Appsecmonarch`}
    description={`Artikel dengan tag ${tag}`}
>
    <section class="tag-section">
        <!-- Back link -->
        <div class="back-wrap fade-in-up">
            <a href="/tags" class="back-link">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                    stroke-width="2" stroke="currentColor" class="back-arrow" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Semua Tags
            </a>
        </div>

        <!-- Header -->
        <div class="tag-header fade-in-up">
            <div class="code-label">// TAG</div>
            <h1 class="tag-heading">
                <em class="em-accent">#{tag}</em>
            </h1>
            <p class="tag-sub">
                {sortedPosts.length} artikel ditemukan
            </p>
        </div>

        <!-- Posts list -->
        {sortedPosts.length > 0 ? (
            <div class="posts-list">
                {sortedPosts.map((post) => {
                    const dateStr = post.data.pubDate.toLocaleDateString("id-ID", {
                        day: "numeric", month: "long", year: "numeric",
                    });
                    return (
                        <a
                            href={`/blog/${post.slug}`}
                            class="post-item fade-in-up"
                        >
                            <div class="post-thumb">
                                {post.data.heroImage
                                    ? <img src={post.data.heroImage} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;border-radius:10px;" />
                                    : <span class="thumb-placeholder">[ image ]</span>
                                }
                            </div>
                            <div class="post-body">
                                <div class="post-tags">
                                    {(post.data.tags ?? []).map((t: string) => (
                                        <span class={`tag${t === tag ? ' tag-active' : ''}`}>#{t}</span>
                                    ))}
                                </div>
                                <h2 class="post-title">{post.data.title}</h2>
                                <p class="post-desc">{post.data.description}</p>
                                <span class="post-date">{dateStr}</span>
                            </div>
                        </a>
                    );
                })}
            </div>
        ) : (
            <p class="empty-msg">Tidak ada artikel dengan tag ini.</p>
        )}
    </section>
</Layout>

<style>
    .tag-section {
        max-width: 1280px;
        margin: 0 auto;
        padding: 4rem 2.5rem 6rem;
    }
    @media (max-width: 640px) { .tag-section { padding: 3rem 1.5rem 5rem; } }

    /* Back link */
    .back-wrap { margin-bottom: 2.5rem; }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #00d4ff;
        font-weight: 500;
        font-size: 0.9375rem;
        text-decoration: none;
        transition: gap 0.2s;
    }
    .back-link:hover { gap: 0.75rem; }
    html:not(.dark) .back-link { color: #003377; }

    .back-arrow {
        width: 18px; height: 18px;
        transition: transform 0.2s;
        flex-shrink: 0;
    }
    .back-link:hover .back-arrow { transform: translateX(-3px); }

    /* Header */
    .code-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        color: #00d4ff;
        letter-spacing: 0.1em;
        opacity: 0.7;
        margin-bottom: 0.75rem;
    }

    .tag-heading {
        font-family: "IBM Plex Serif", serif;
        font-weight: 700;
        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--text);
        margin-bottom: 0.75rem;
        line-height: 1.1;
    }

    .em-accent { font-style: italic; color: #00d4ff; }
    html:not(.dark) .em-accent { color: #003377; }

    .tag-sub {
        font-size: 1rem;
        color: var(--text-muted);
        margin-bottom: 0;
    }

    .tag-header { margin-bottom: 3rem; }

    /* Posts list */
    .posts-list { display: flex; flex-direction: column; }

    .post-item {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 2rem;
        align-items: start;
        padding: 2rem 0;
        border-bottom: 1px solid var(--border);
        text-decoration: none;
        color: var(--text);
        transition: opacity 0.2s;
    }
    @media (max-width: 640px) { .post-item { grid-template-columns: 1fr; } }

    .post-thumb {
        width: 100%;
        aspect-ratio: 4/3;
        border-radius: 10px;
        background: linear-gradient(135deg, #1a2235 0%, #0d1320 100%);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        transition: border-color 0.2s;
    }
    html:not(.dark) .post-thumb { background: linear-gradient(135deg, #e2e8f0 0%, #f1f5f9 100%); }
    .post-item:hover .post-thumb { border-color: rgba(0, 212, 255, 0.25); }

    .thumb-placeholder {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.65rem;
        color: #4a5568;
    }
    html:not(.dark) .thumb-placeholder { color: #94a3b8; }

    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.625rem; }

    .tag {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.7rem;
        color: #00d4ff;
        background: rgba(0, 212, 255, 0.08);
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
    }
    .tag-active {
        background: rgba(0, 212, 255, 0.18);
        border: 1px solid rgba(0, 212, 255, 0.3);
    }

    .post-title {
        font-family: "IBM Plex Serif", serif;
        font-weight: 700;
        font-size: 1.375rem;
        line-height: 1.3;
        color: var(--text);
        margin-bottom: 0.625rem;
        transition: color 0.2s;
    }
    .post-item:hover .post-title { color: #00d4ff; }
    html:not(.dark) .post-item:hover .post-title { color: #003377; }

    .post-desc {
        font-size: 0.9375rem;
        color: var(--text-muted);
        line-height: 1.65;
        margin-bottom: 1rem;
    }

    .post-date { font-size: 0.8rem; color: var(--text-dim); }

    .empty-msg { font-size: 1rem; color: var(--text-muted); }
</style>

<script>
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
