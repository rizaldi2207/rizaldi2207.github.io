---
import Layout from "../layouts/Layout.astro";
---
<Layout
  title="Hubungi Kami - Appsecmonarch"
  description="Temukan kami di berbagai platform sosial media."
>
  <section class="py-20 px-6 flex flex-col items-center justify-center min-h-[60vh] text-center">
    <span class="text-xs font-semibold tracking-widest uppercase text-primary opacity-70 mb-5">
      Hubungi Kami
    </span>
    <h1 class="font-serif text-5xl md:text-6xl font-bold leading-tight mb-5">
      Mari Terhubung<br /><em class="text-primary">Bersama Kami</em>
    </h1>
    <p class="text-lg text-gray-600 max-w-lg mb-14">
      Temukan kami di berbagai platform — siap berdiskusi seputar keamanan aplikasi, kolaborasi, atau sekadar menyapa.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 max-w-2xl w-full">
      <!-- Instagram -->
      <a href="https://instagram.com/appsecmonarch" target="_blank" rel="noopener noreferrer" class="social-card instagram-card group">
        <div class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </div>
        <span class="social-name">Instagram</span>
        <span class="social-handle">@appsecmonarch</span>
      </a>

      <!-- LinkedIn -->
      <a href="https://linkedin.com/company/appsecmonarch" target="_blank" rel="noopener noreferrer" class="social-card linkedin-card group">
        <div class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <span class="social-name">LinkedIn</span>
        <span class="social-handle">Appsecmonarch</span>
      </a>

      <!-- GitHub -->
      <a href="https://github.com/appsecmonarch" target="_blank" rel="noopener noreferrer" class="social-card github-card group">
        <div class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </div>
        <span class="social-name">GitHub</span>
        <span class="social-handle">@appsecmonarch</span>
      </a>

      <!-- Discord -->
      <a href="https://discord.gg/appsecmonarch" target="_blank" rel="noopener noreferrer" class="social-card discord-card group">
        <div class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.056a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
          </svg>
        </div>
        <span class="social-name">Discord</span>
        <span class="social-handle">appsecmonarch</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .social-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
    border-radius: 1rem;
    border: 1.5px solid #e5e7eb;
    background: #fff;
    transition: all 0.3s ease;
    text-decoration: none;
    color: #374151;
  }

  .social-icon {
    transition: transform 0.3s ease;
  }

  .social-card:hover .social-icon {
    transform: scale(1.15);
  }

  .social-name {
    font-weight: 700;
    font-size: 0.9rem;
  }

  .social-handle {
    font-size: 0.72rem;
    opacity: 0.65;
  }

  /* Instagram — gradient merah-oranye-ungu */
  .instagram-card:hover {
    background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 8px 24px rgba(220, 39, 67, 0.35);
  }

  /* LinkedIn — biru khas LinkedIn */
  .linkedin-card:hover {
    background: #0A66C2;
    border-color: transparent;
    color: #fff;
    box-shadow: 0 8px 24px rgba(10, 102, 194, 0.35);
  }

  /* GitHub — hitam */
  .github-card:hover {
    background: #181717;
    border-color: transparent;
    color: #fff;
    box-shadow: 0 8px 24px rgba(24, 23, 23, 0.35);
  }

  /* Discord — ungu Discord */
  .discord-card:hover {
    background: #5865F2;
    border-color: transparent;
    color: #fff;
    box-shadow: 0 8px 24px rgba(88, 101, 242, 0.35);
  }

  .social-card:hover .social-handle {
    opacity: 0.85;
  }
</style>