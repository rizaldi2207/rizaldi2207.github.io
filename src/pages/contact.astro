---
import Layout from "../layouts/Layout.astro";

const email = "halo@appsecmonarch.id";

const socials = [
    {
        label: "Instagram",
        handle: "@appsecmonarch",
        href: "https://www.instagram.com/appsecmonarch/",
        icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/></svg>`,
    },
    {
        label: "LinkedIn",
        handle: "appsecmonarch",
        href: "https://linkedin.com/company/appsecmonarch",
        icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
    },
    {
        label: "GitHub",
        handle: "appsecmonarch",
        href: "https://github.com/appsecmonarch",
        icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
    },
    {
        label: "Discord",
        handle: "Appsecmonarch",
        href: "https://discord.gg/appsecmonarch",
        icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>`,
    },
];

const purposes = [
    {
        title: "Konsultasi",
        desc: "Ada masalah security spesifik di tim atau produk kamu? Ceritakan gejalanya — kita cek bareng apakah worth ditindaklanjuti.",
    },
    {
        title: "Ide topik",
        desc: "Ada konsep security yang bikin bingung dan ingin kami bahas? Kirim — banyak tulisan kami lahir dari pertanyaan pembaca.",
    },
    {
        title: "Umum & kolaborasi",
        desc: "Ngobrol santai, sapaan, atau ajakan kerja sama. Pintunya terbuka — kirim saja ke email di samping.",
    },
];
---

<Layout
    title="Hubungi Kami — Appsecmonarch"
    description="Punya pertanyaan, ide topik, atau masalah security yang ingin dibahas? Kami paling gampang dihubungi lewat email dan sosial media."
>
    <!-- ══════════ HERO ══════════ -->
    <section class="contact-hero">
        <div class="contact-hero-inner">
            <p class="eyebrow">Hubungi kami</p>
            <h1 class="hero-heading">Mari ngobrol.</h1>
            <p class="hero-sub">
                Punya pertanyaan, ide topik, atau masalah security yang ingin dibahas?
                Kami paling gampang dihubungi lewat email dan sosial media di bawah.
            </p>
        </div>
    </section>

    <!-- ══════════ KONTAK ══════════ -->
    <section class="contact-main fade-in-up">
        <div class="contact-cols">
            <!-- Email + sosial -->
            <div class="reach-panel">
                <p class="eyebrow eyebrow-on-deep">Email langsung</p>
                <a href={`mailto:${email}`} class="email-link">{email}</a>
                <p class="email-note">
                    Kami balas dalam 1–2 hari kerja. Ceritakan konteksnya sedetail yang kamu
                    bisa — makin jelas, makin cepat kami bantu.
                </p>

                <p class="eyebrow eyebrow-on-deep">Temui kami di</p>
                <div class="social-list">
                    {socials.map(({ label, handle, href, icon }) => (
                        <a
                            href={href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="social-row"
                        >
                            <span class="social-icon"><Fragment set:html={icon} /></span>
                            <span class="social-info">
                                <span class="social-label">{label}</span>
                                <span class="social-handle">{handle}</span>
                            </span>
                            <span class="social-arrow" aria-hidden="true">→</span>
                        </a>
                    ))}
                </div>
            </div>

            <!-- Untuk apa -->
            <div class="purpose-col">
                <p class="eyebrow">Untuk apa kamu ingin terhubung?</p>
                {purposes.map(({ title, desc }) => (
                    <div class="purpose-card">
                        <h3 class="purpose-title">{title}</h3>
                        <p class="purpose-desc">{desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>
</Layout>

<style>
    /* ── Hero ── */
    .contact-hero {
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
    }
    .contact-hero-inner { max-width: 1180px; margin: 0 auto; padding: 80px 40px 64px; }
    @media (max-width: 640px) { .contact-hero-inner { padding: 56px 24px 40px; } }

    .hero-heading {
        font-size: clamp(2rem, 5vw, 50px);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 20px;
    }
    .hero-sub {
        font-size: 18px;
        color: var(--text-muted);
        line-height: 1.75;
        max-width: 680px;
    }

    /* ── Kolom ── */
    .contact-main { max-width: 1180px; margin: 0 auto; padding: 64px 40px 96px; }
    @media (max-width: 640px) { .contact-main { padding: 40px 24px 64px; } }

    .contact-cols { display: flex; gap: 32px; align-items: stretch; }
    @media (max-width: 900px) { .contact-cols { flex-direction: column; } }

    /* ── Panel navy ── */
    .reach-panel {
        flex: 1.05;
        background: var(--surface-deep);
        border-radius: 18px;
        padding: 48px 46px;
        display: flex;
        flex-direction: column;
    }
    @media (max-width: 640px) { .reach-panel { padding: 36px 28px; } }

    .reach-panel .eyebrow { margin-bottom: 16px; }

    .email-link {
        font-family: Syne, sans-serif;
        font-size: clamp(1.375rem, 3vw, 30px);
        font-weight: 700;
        color: var(--surface-deep-text);
        letter-spacing: -0.02em;
        text-decoration: none;
        margin-bottom: 12px;
        word-break: break-word;
        transition: color 0.2s;
    }
    .email-link:hover { color: var(--accent); }

    .email-note {
        font-size: 15px;
        color: var(--surface-deep-dim);
        line-height: 1.7;
        margin-bottom: 40px;
    }

    .social-list { display: flex; flex-direction: column; gap: 12px; }

    .social-row {
        display: flex;
        align-items: center;
        gap: 16px;
        background: var(--surface-deep-card);
        border: 1px solid var(--surface-deep-border);
        border-radius: 12px;
        padding: 16px 20px;
        text-decoration: none;
        transition: background 0.2s, border-color 0.2s;
    }
    .social-row:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(0, 112, 208, 0.5);
    }
    html.dark .social-row:hover { border-color: var(--accent); }

    .social-icon {
        color: var(--surface-deep-text);
        display: flex;
        flex-shrink: 0;
    }
    .social-info { flex: 1; display: flex; flex-direction: column; gap: 2px; }
    .social-label { font-size: 15px; font-weight: 600; color: var(--surface-deep-text); }
    .social-handle { font-size: 13px; color: var(--surface-deep-dim); }
    .social-arrow { color: var(--surface-deep-dim); font-size: 18px; transition: transform 0.2s; }
    .social-row:hover .social-arrow { transform: translateX(3px); }

    /* ── Kartu tujuan ── */
    .purpose-col { flex: 1; display: flex; flex-direction: column; gap: 20px; }
    .purpose-col .eyebrow { margin-bottom: 0; letter-spacing: 0.18em; }

    .purpose-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 28px 30px;
        transition: border-color 0.25s, box-shadow 0.25s;
    }
    .purpose-card:hover { border-color: #b8d3ef; box-shadow: var(--shadow-card); }
    html.dark .purpose-card:hover { border-color: var(--accent); }

    .purpose-title { font-size: 20px; font-weight: 700; margin-bottom: 9px; }
    .purpose-desc { font-size: 14.5px; color: var(--text-muted); line-height: 1.7; }
</style>

<script>
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
