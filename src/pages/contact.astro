---

<Layout
    title="Hubungi Kami — Appsecmonarch"
    description="Temukan kami di berbagai platform sosial media."
>
    <section class="contact-section">
        <div class="contact-header fade-in-up">
            <div class="code-label">// CONNECT_WITH_US</div>
            <h1 class="contact-heading">
                Mari Terhubung <em class="em-accent">Bersama Kami</em>
            </h1>
            <p class="contact-sub">
                Temukan kami di berbagai platform — siap berdiskusi seputar
                keamanan aplikasi, kolaborasi, atau sekadar menyapa.
            </p>
        </div>

        <div class="socials-grid">
            {socials.map(({ label, handle, href, cardClass, icon }) => (
                <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`social-card ${cardClass} fade-in-up`}
                    aria-label={label}
                >
                    <!-- Glow blob -->
                    <div class="glow-blob"></div>

                    <!-- Icon -->
                    <div class="icon-wrap">
                        <Fragment set:html={icon} />
                    </div>

                    <!-- Label + handle -->
                    <div class="card-info">
                        <div class="card-name">{label}</div>
                        <div class="card-handle">{handle}</div>
                    </div>

                    <!-- Visit link -->
                    <div class="card-visit">
                        Kunjungi
                        <svg viewBox="0 0 16 16" fill="none" class="visit-arrow" aria-hidden="true">
                            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                </a>
            ))}
        </div>
    </section>
</Layout>

<style>
    .code-label {
        font-family: "JetBrains Mono", monospace; font-size: 0.7rem;
        color: #00d4ff; letter-spacing: 0.1em; opacity: 0.7; margin-bottom: 1rem;
    }
    html:not(.dark) .code-label { color: #003377; }
    .em-accent { font-style: italic; color: #00d4ff; }
    html:not(.dark) .em-accent { color: #003377; }

    /* ── Contact section ── */
    .contact-section {
        max-width: 1280px; margin: 0 auto;
        padding: 4rem 2.5rem 8rem;
    }
    @media (max-width: 640px) { .contact-section { padding: 3rem 1.5rem 6rem; } }

    .contact-header { text-align: center; margin-bottom: 4rem; }

    .contact-heading {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: clamp(2.5rem, 5vw, 3.75rem);
        line-height: 1.1; color: var(--text); margin-bottom: 1.25rem;
    }
    .contact-sub {
        font-size: 1.0625rem; color: var(--text-muted);
        max-width: 480px; margin: 0 auto; line-height: 1.7;
    }

    /* ── Socials grid ── */
    .socials-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        max-width: 860px;
        margin: 0 auto;
    }
    @media (max-width: 860px) { .socials-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .socials-grid { grid-template-columns: 1fr; } }

    /* ── Social card ── */
    .social-card {
        display: flex; flex-direction: column; align-items: center;
        gap: 1.25rem; padding: 2.5rem 1.5rem 2.25rem;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 16px; text-decoration: none; color: var(--text);
        transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
        position: relative; overflow: hidden;
        box-shadow: none;
    }
    .social-card:hover {
        transform: translateY(-8px) scale(1.02);
        border-color: transparent;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.2);
    }

    /* Per-card hover background */
    .card-instagram:hover { background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
    .card-linkedin:hover  { background: #0077b5; }
    .card-github:hover    { background: #24292e; }
    .card-discord:hover   { background: #5865F2; }

    /* Glow blob */
    .glow-blob {
        position: absolute; top: -30px; right: -30px;
        width: 100px; height: 100px; border-radius: 50%;
        background: transparent; filter: blur(20px);
        transition: background 0.3s; pointer-events: none;
    }
    .social-card:hover .glow-blob { background: rgba(255,255,255,0.12); }

    /* Icon wrap */
    .icon-wrap {
        width: 64px; height: 64px; border-radius: 16px;
        background: rgba(0,212,255,0.08);
        display: flex; align-items: center; justify-content: center;
        color: #00d4ff;
        transition: all 0.25s ease;
        position: relative; z-index: 1;
    }
    html:not(.dark) .icon-wrap { background: rgba(0,51,119,0.08); color: #003377; }
    .icon-wrap :global(svg) { width: 30px; height: 30px; }
    .social-card:hover .icon-wrap { background: rgba(255,255,255,0.15); color: #fff; }

    /* Card info */
    .card-info { text-align: center; position: relative; z-index: 1; }
    .card-name {
        font-weight: 700; font-size: 1rem; letter-spacing: 0.01em;
        color: var(--text); margin-bottom: 0.25rem;
        transition: color 0.25s;
    }
    .card-handle {
        font-family: "JetBrains Mono", monospace; font-size: 0.75rem;
        color: var(--text-muted); transition: color 0.25s;
    }
    .social-card:hover .card-name,
    .social-card:hover .card-handle { color: rgba(255,255,255,0.9); }

    /* Visit link */
    .card-visit {
        font-size: 0.8rem; font-weight: 500;
        color: #00d4ff;
        display: flex; align-items: center; gap: 0.375rem;
        position: relative; z-index: 1; transition: color 0.25s;
    }
    html:not(.dark) .card-visit { color: #003377; }
    .social-card:hover .card-visit { color: rgba(255,255,255,0.9); }

    .visit-arrow {
        width: 14px; height: 14px;
        transition: transform 0.2s;
    }
    .social-card:hover .visit-arrow { transform: translateX(3px); }
</style>

<script>
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
