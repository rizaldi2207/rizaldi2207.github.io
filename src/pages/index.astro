---
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latest = posts.slice(0, 3);

// The design's three topic cards map onto posts that already exist, so they
// link to real articles instead of standing as decoration. Any slug that goes
// missing simply drops out rather than rendering a dead link.
const topicSource = [
    {
        slug: "injection",
        title: "Injection",
        desc: "Input jahat yang masuk ke interpreter. Kenali polanya, biasakan parameterized query, tutup celah paling klasik.",
        tile: "tile-deep",
    },
    {
        slug: "error-handling",
        title: "Error Handling",
        desc: "Pesan error yang membocorkan isi dapur sistem. Detail cukup di log server; user cukup lihat pesan yang tenang.",
        tile: "tile-mid",
    },
    {
        slug: "humanfirewall",
        title: "Human Firewall",
        desc: "Teknologi menutup sebagian celah. Sisanya soal kebiasaan tim — dan kebiasaan bisa dilatih.",
        tile: "tile-accent",
    },
];
const topics = topicSource.filter((t) => posts.some((p) => p.slug === t.slug));

const fmtDate = (d: Date) =>
    d.toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" });
---

<Layout
    title="Appsecmonarch — Komunitas Application Security Indonesia"
    description="Belajar keamanan aplikasi, satu konsep dalam satu waktu. Catatan dan penjelasan security untuk developer — dari kenapa celah terjadi sampai cara menutupnya."
>
    <!-- ══════════ HERO ══════════ -->
    <section class="hero">
        <div class="hero-inner">
            <div class="hero-text">
                <div class="hero-eyebrow">
                    <span class="eyebrow-rule"></span>
                    <p class="eyebrow" style="margin-bottom:0;">Application Security · Indonesia</p>
                </div>

                <h1 class="hero-heading">
                    Belajar keamanan aplikasi, satu konsep dalam satu waktu.
                </h1>

                <p class="hero-sub">
                    Catatan, tips, dan penjelasan security untuk developer — dari kenapa
                    sebuah celah bisa terjadi sampai bagaimana menutupnya, lengkap dengan
                    contoh nyata.
                </p>

                <div class="hero-actions">
                    <a href="/blog" class="btn-primary">Baca artikel</a>
                    <a href="/contact" class="btn-secondary">Ajukan konsultasi</a>
                </div>
            </div>

            <div class="hero-visual">
                <div class="hero-frame">
                    <img
                        src="/assets/securecode.png"
                        alt="Tim developer berdiskusi di depan laptop dengan lambang keamanan kode"
                        class="hero-img"
                    />
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                            stroke-linejoin="round" aria-hidden="true">
                            <path d="M12 3l7 3v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6l7-3z" />
                            <path d="M9 12l2 2 4-4" />
                        </svg>
                    </div>
                    <div>
                        <p class="hero-stat-val">{posts.length} tulisan</p>
                        <p class="hero-stat-lbl">tips &amp; konsep security</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════ TOPIK ══════════ -->
    <section class="topics fade-in-up">
        <div class="topics-head">
            <p class="eyebrow">Yang sering dibahas</p>
            <h2 class="topics-title">Tiga hal yang paling sering terlewat</h2>
        </div>

        <div class="topics-grid">
            {topics.map(({ slug, title, desc, tile }) => (
                <a href={`/blog/${slug}`} class="topic-card">
                    <div class={`topic-icon ${tile}`}>
                        {slug === "injection" && (
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff"
                                stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
                            </svg>
                        )}
                        {slug === "error-handling" && (
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff"
                                stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="9" /><line x1="12" y1="8" x2="12" y2="13" />
                                <circle cx="12" cy="16.5" r="0.6" fill="#fff" stroke="none" />
                            </svg>
                        )}
                        {slug === "humanfirewall" && (
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff"
                                stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" /><circle cx="10" cy="7" r="4" />
                                <path d="M21 21v-2a4 4 0 0 0-3-3.87" />
                            </svg>
                        )}
                    </div>
                    <h3 class="topic-title">{title}</h3>
                    <p class="topic-desc">{desc}</p>
                </a>
            ))}
        </div>
    </section>

    <!-- ══════════ TULISAN TERBARU ══════════ -->
    <section class="latest fade-in-up">
        <div class="latest-head">
            <div>
                <p class="eyebrow">Tulisan terbaru</p>
                <h2 class="latest-title">Baru dari blog</h2>
            </div>
            <a href="/blog" class="link-accent">Lihat semua →</a>
        </div>

        <div class="post-grid">
            {latest.map((post) => (
                <a href={`/blog/${post.slug}`} class="post-card">
                    <div class="post-media">
                        {post.data.heroImage && (
                            <img src={post.data.heroImage} alt="" class="post-img" />
                        )}
                    </div>
                    <div class="post-body">
                        {post.data.tags?.[0] && (
                            <span class="post-cat">{post.data.tags[0]}</span>
                        )}
                        <h3 class="post-title">{post.data.title}</h3>
                        <p class="post-excerpt">{post.data.description}</p>
                        <p class="post-meta">Appsecmonarch · {fmtDate(post.data.pubDate)}</p>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <!-- ══════════ FILOSOFI ══════════ -->
    <section class="philosophy fade-in-up">
        <div class="philosophy-inner">
            <p class="quote-mark" aria-hidden="true">&ldquo;</p>
            <blockquote class="quote-text">
                Kode yang aman bukan kode yang sempurna — tapi kode yang kamu pahami sepenuhnya.
            </blockquote>
            <div class="quote-attr">
                <span class="eyebrow-rule"></span>
                <p class="quote-handle">@appsecmonarch</p>
            </div>
        </div>
    </section>

    <!-- ══════════ CTA KONSULTASI ══════════ -->
    <section class="consult fade-in-up">
        <div class="consult-inner">
            <div class="consult-text">
                <h2 class="consult-title">Ada gejala security yang mengganjal di tim kamu?</h2>
                <p class="consult-sub">
                    Nggak semua masalah butuh konsultan. Tapi yang ini biasanya lebih cepat kalau
                    ada yang sudah pernah mengalaminya. Ceritakan situasimu, kita ngobrol.
                </p>
            </div>
            <a href="/contact" class="btn-primary consult-btn">Hubungi kami</a>
        </div>
    </section>
</Layout>

<style>
    /* ── Shared ── */
    .btn-primary {
        background: var(--accent);
        color: var(--accent-contrast);
        font-size: 16px;
        font-weight: 600;
        padding: 15px 30px;
        border-radius: 9px;
        text-decoration: none;
        display: inline-block;
        transition: background 0.2s;
    }
    .btn-primary:hover { background: var(--accent-hover); }

    .btn-secondary {
        border: 1.5px solid var(--border-strong);
        color: var(--text);
        font-size: 16px;
        font-weight: 600;
        padding: 15px 30px;
        border-radius: 9px;
        text-decoration: none;
        display: inline-block;
        transition: border-color 0.2s, color 0.2s;
    }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

    .link-accent {
        font-size: 15px;
        font-weight: 600;
        color: var(--accent);
        text-decoration: none;
        transition: color 0.2s;
    }
    .link-accent:hover { color: var(--accent-hover); }

    /* ── Hero ── */
    .hero {
        background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg) 100%);
        border-bottom: 1px solid var(--border);
    }
    .hero-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 88px 40px 96px;
        display: flex;
        align-items: center;
        gap: 72px;
    }
    @media (max-width: 900px) {
        .hero-inner { flex-direction: column; align-items: flex-start; gap: 56px; padding: 56px 24px 72px; }
    }

    .hero-text { flex: 1.05; }
    .hero-eyebrow { display: flex; align-items: center; gap: 11px; margin-bottom: 26px; }

    .hero-heading {
        font-size: clamp(2.25rem, 5vw, 56px);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.08;
        margin-bottom: 24px;
    }
    .hero-sub {
        font-size: 18px;
        color: var(--text-muted);
        line-height: 1.7;
        max-width: 520px;
        margin-bottom: 36px;
    }
    .hero-actions { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }

    .hero-visual { flex: 0.95; position: relative; width: 100%; }
    .hero-frame {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow-panel);
        aspect-ratio: 4/3;
        background: var(--surface-deep);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 28px;
    }
    /* The illustration is a transparent PNG, so it is contained on the navy
       panel rather than cropped by object-fit: cover. */
    .hero-img { width: 100%; height: 100%; object-fit: contain; }

    .hero-stat {
        position: absolute;
        bottom: -22px;
        left: -22px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 12px 34px rgba(0, 24, 64, 0.14);
        padding: 18px 22px;
        display: flex;
        align-items: center;
        gap: 14px;
    }
    @media (max-width: 900px) { .hero-stat { left: 0; bottom: -18px; } }

    .hero-stat-icon {
        width: 44px; height: 44px;
        border-radius: 10px;
        background: var(--accent-soft);
        color: var(--accent);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .hero-stat-val {
        font-family: Syne, sans-serif;
        font-size: 19px; font-weight: 700;
        color: var(--text); line-height: 1;
    }
    .hero-stat-lbl { font-size: 12px; color: var(--text-dim); margin-top: 4px; }

    /* ── Topik ── */
    .topics { max-width: 1180px; margin: 0 auto; padding: 88px 40px 40px; }
    @media (max-width: 640px) { .topics { padding: 64px 24px 32px; } }

    .topics-head { text-align: center; margin-bottom: 52px; }
    .topics-title { font-size: clamp(1.75rem, 4vw, 38px); font-weight: 700; }

    .topics-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
    @media (max-width: 900px) { .topics-grid { grid-template-columns: 1fr; } }

    .topic-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 34px 30px;
        text-decoration: none;
        display: block;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }
    .topic-card:hover {
        border-color: #b8d3ef;
        box-shadow: var(--shadow-card);
        transform: translateY(-3px);
    }
    html.dark .topic-card:hover { border-color: var(--accent); }

    .topic-icon {
        width: 52px; height: 52px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 22px;
    }
    /* Three deliberate shades give the row rhythm. In dark mode the deep navies
       would sink into the card, so they lift to stay legible. */
    .tile-deep { background: #001840; }
    .tile-mid { background: #003080; }
    .tile-accent { background: var(--accent); }
    html.dark .tile-deep { background: #0d3a7a; }
    html.dark .tile-mid { background: #0a4f9e; }

    .topic-title { font-size: 21px; font-weight: 700; margin-bottom: 11px; }
    .topic-desc { font-size: 14.5px; color: var(--text-muted); line-height: 1.7; }

    /* ── Tulisan terbaru ── */
    .latest { max-width: 1180px; margin: 0 auto; padding: 64px 40px 88px; }
    @media (max-width: 640px) { .latest { padding: 48px 24px 64px; } }

    .latest-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 36px;
        flex-wrap: wrap;
    }
    .latest-title { font-size: clamp(1.625rem, 3.5vw, 34px); font-weight: 700; }

    .post-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    @media (max-width: 900px) { .post-grid { grid-template-columns: 1fr; } }

    .post-card {
        display: block;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        text-decoration: none;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }
    .post-card:hover {
        border-color: #b8d3ef;
        box-shadow: var(--shadow-card-hover);
        transform: translateY(-3px);
    }
    html.dark .post-card:hover { border-color: var(--accent); }

    .post-media { aspect-ratio: 16/10; background: var(--media-bg); overflow: hidden; }
    .post-img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .post-body { padding: 24px 24px 26px; }

    .post-cat {
        display: inline-flex;
        background: var(--accent-soft);
        color: var(--accent);
        border-radius: 6px;
        padding: 4px 11px;
        margin-bottom: 14px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
    .post-title {
        font-size: 19px; font-weight: 700;
        line-height: 1.32; margin-bottom: 10px;
        transition: color 0.2s;
    }
    .post-card:hover .post-title { color: var(--accent); }
    .post-excerpt {
        font-size: 14px; color: var(--text-muted);
        line-height: 1.65; margin-bottom: 18px;
        display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .post-meta { font-size: 12.5px; color: var(--text-dim); letter-spacing: 0.02em; }

    /* ── Filosofi ── */
    .philosophy { background: var(--surface-deep); }
    .philosophy-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 96px 40px;
        text-align: center;
    }
    @media (max-width: 640px) { .philosophy-inner { padding: 64px 24px; } }

    .quote-mark {
        font-family: Syne, sans-serif;
        font-size: 90px;
        font-weight: 800;
        color: var(--accent);
        line-height: 0.4;
        margin-bottom: 20px;
    }
    .quote-text {
        font-family: Syne, sans-serif;
        font-size: clamp(1.5rem, 4vw, 38px);
        font-weight: 600;
        color: var(--surface-deep-text);
        line-height: 1.4;
        letter-spacing: -0.02em;
        max-width: 860px;
        margin: 0 auto 26px;
    }
    .quote-attr { display: flex; align-items: center; justify-content: center; gap: 11px; }
    .quote-handle { font-size: 14px; color: var(--surface-deep-dim); letter-spacing: 0.04em; }

    /* ── CTA Konsultasi ── */
    .consult { max-width: 1180px; margin: 0 auto; padding: 96px 40px; }
    @media (max-width: 640px) { .consult { padding: 64px 24px; } }

    .consult-inner {
        background: linear-gradient(135deg, var(--accent-soft) 0%, var(--bg-secondary) 100%);
        border: 1px solid var(--border-strong);
        border-radius: 20px;
        padding: 64px 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 48px;
    }
    @media (max-width: 900px) {
        .consult-inner { flex-direction: column; align-items: flex-start; padding: 40px 32px; gap: 32px; }
    }

    .consult-text { max-width: 620px; }
    .consult-title {
        font-size: clamp(1.5rem, 3.5vw, 34px);
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 16px;
    }
    .consult-sub { font-size: 16.5px; color: var(--text-muted); line-height: 1.7; }
    .consult-btn { flex-shrink: 0; padding: 16px 34px; border-radius: 10px; }
</style>

<script>
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
