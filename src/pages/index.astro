---
import Layout from "../layouts/Layout.astro";
import BlogCard from "../components/BlogCard.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts = (await getCollection("blog")).sort(
	(a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
		b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
	title="Astro Blog - Minimalist Indonesian Blog"
	description="A simple, clean blog built with Astro."
>
	<section class="py-12 md:py-20 px-6 md:px-12 max-w-7xl mx-auto">
		<div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
			<div class="flex-1 max-w-3xl">
				<h1
					class="text-4xl md:text-6xl font-serif font-bold text-gray-900 mb-6 leading-tight"
				>
					Learn, Share & <span class="text-primary italic"
						>Secure</span
					>
				</h1>
				<p
					class="text-xl md:text-2xl text-gray-600 leading-relaxed font-serif"
				>
					Ketika Security Engineer berstrategi dan Developer mengeksekusi, lahirlah aplikasi yang aman dan tangguh.
				</p>
			</div>
			<div class="flex-1 w-full md:w-auto">
				<img 
					src="/src/assets/securityawareness-removebg-preview.png"
					alt="Security and Development" 
					class="w-full h-auto object-cover"
				/>
			</div>
		</div>
	</section>

	<section class="py-12 md:py-20 px-6 md:px-12 max-w-7xl mx-auto">
		<div class="flex flex-col md:flex-row-reverse items-center gap-8 md:gap-12">
			<div class="flex-1 max-w-3xl">
				<h1
					class="text-2xl md:text-3xl font-serif font-bold text-gray-900 mb-3 leading-tight group-hover:text-primary transition-colors"
				>
					Siapa <span class="text-primary italic"
						>Appsecmonarch</span
					>?
				</h1>
				<p
					class="mx-auto prose prose-lg prose-headings:font-serif prose-headings:font-bold prose-headings:text-gray-900 prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg"
				>
					Komunitas AppSec adalah sebuah ekosistem di mana Security Engineer dan Developer bekerja sama secara sinergis untuk melindungi Aplikasi dan Penggunanya dari segala ancaman siber. Kolaborasi inilah yang menjadi inti dari komunitas AppSec. Sinergi antara strategi (oleh Security Engineer) dan eksekusi (oleh Developer) adalah kunci untuk membangun aplikasi yang tidak hanya berfungsi, tetapi juga tahan banting dan aman.
				</p>
			</div>
			<div class="flex-1 w-full md:w-auto">
				<img 
					src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80" 
					alt="AppSec Community" 
					class="rounded-lg shadow-lg w-full h-auto object-cover"
				/>
			</div>
		</div>
	</section>
</Layout>
