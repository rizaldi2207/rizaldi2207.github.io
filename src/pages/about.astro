---
import Layout from "../layouts/Layout.astro";

// Brand voice principles, taken from the design handoff / Brand Identity doc.
const principles = [
    {
        no: "01",
        title: "Casual tapi informatif",
        desc: "Santai dan mudah didekati, tapi tetap berisi dan tepat sasaran. Bahasa manusia, bukan salinan dokumentasi.",
    },
    {
        no: "02",
        title: "Padat, no fluff",
        desc: "Satu topik per tulisan, tanpa filler. Kami hargai waktumu — langsung ke inti, contoh nyata, selesai.",
    },
    {
        no: "03",
        title: "Empowering",
        desc: "Security bisa dipelajari siapa saja, bukan hak eksklusif expert. Tujuan kami membuatmu lebih percaya diri, bukan takut.",
    },
];

const pillars = [
    {
        title: "Learn",
        desc: "Menjelaskan konsep security dari nol — pelan, urut, dan bisa langsung dipraktikkan di kode kamu.",
    },
    {
        title: "Share",
        desc: "Membagikan tips, tren, dan pelajaran dari kasus nyata. Belajar bareng jauh lebih cepat daripada sendirian.",
    },
    {
        title: "Secure",
        desc: "Membantu tim membereskan masalah security lewat konsultasi, berdasarkan pengalaman menangani hal serupa.",
    },
];

const team = [
    {
        name: "Thomson Rihad Dody Malau",
        role: "Security Engineer",
        description: "Security Engineer dengan pengalaman 6+ tahun dalam membangun infrastruktur yang aman dan scalable.",
    },
    {
        name: "Zahra Nabila Putri",
        role: "Application Security Specialist",
        description: "Spesialis keamanan aplikasi yang fokus pada penerapan best practices secure coding dan vulnerability management.",
    },
    {
        name: "Rizaldi Sanjaya",
        role: "DevSecOps Engineer",
        description: "Membangun security automation pada CI/CD pipeline untuk aplikasi modern.",
    },
    {
        name: "Yunita Ariswanti Purnama Putri",
        role: "Content Writer",
        description: "Technical writer yang mengubah konsep kompleks menjadi konten yang mudah dipahami.",
    },
];

const initials = (name: string) =>
    name.split(" ").slice(0, 2).map((n) => n[0]).join("");
---

<Layout
    title="Tentang Kami — Appsecmonarch"
    description="appsecmonarch dibuat untuk developer yang ingin paham keamanan tanpa harus merasa bodoh dulu — dibahas pelan dari nol sampai bisa langsung dipraktikkan."
>
    <!-- ══════════ HERO ══════════ -->
    <section class="about-hero">
        <div class="about-hero-inner">
            <p class="eyebrow">Tentang</p>
            <h1 class="hero-heading">
                Teman yang kebetulan tahu lebih banyak soal security.
            </h1>
            <p class="hero-sub">
                appsecmonarch dibuat untuk developer yang ingin paham keamanan tanpa harus
                merasa bodoh dulu. Kami mulai dari pertanyaan yang sering kamu ragu tanyakan,
                lalu bahas pelan sampai bisa langsung kamu praktikkan.
            </p>
        </div>
    </section>

    <!-- ══════════ PRINSIP ══════════ -->
    <section class="principles fade-in-up">
        <div class="principles-grid">
            {principles.map(({ no, title, desc }) => (
                <div class="principle-card">
                    <p class="principle-no">{no}</p>
                    <h3 class="principle-title">{title}</h3>
                    <p class="principle-desc">{desc}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- ══════════ LEARN · SHARE · SECURE ══════════ -->
    <section class="pillars fade-in-up">
        <div class="pillars-band">
            <p class="eyebrow eyebrow-on-deep">Yang kami lakukan</p>
            <div class="pillars-grid">
                {pillars.map(({ title, desc }) => (
                    <div class="pillar">
                        <h3 class="pillar-title">{title}</h3>
                        <p class="pillar-desc">{desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ══════════ TIM ══════════ -->
    <section class="team fade-in-up">
        <div class="team-head">
            <p class="eyebrow">Orang di baliknya</p>
            <h2 class="team-heading">Tim kami</h2>
        </div>
        <div class="team-grid">
            {team.map((member) => (
                <div class="team-card">
                    <div class="avatar" aria-hidden="true">{initials(member.name)}</div>
                    <div>
                        <h3 class="team-name">{member.name}</h3>
                        <p class="team-role">{member.role}</p>
                        <p class="team-desc">{member.description}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>
</Layout>

<style>
    /* ── Hero ── */
    .about-hero {
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
    }
    .about-hero-inner { max-width: 1180px; margin: 0 auto; padding: 80px 40px; }
    @media (max-width: 640px) { .about-hero-inner { padding: 56px 24px; } }

    .hero-heading {
        font-size: clamp(2rem, 5vw, 50px);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.08;
        max-width: 820px;
        margin-bottom: 24px;
    }
    .hero-sub {
        font-size: 18px;
        color: var(--text-muted);
        line-height: 1.75;
        max-width: 720px;
    }

    /* ── Prinsip ── */
    .principles { max-width: 1180px; margin: 0 auto; padding: 88px 40px 40px; }
    @media (max-width: 640px) { .principles { padding: 64px 24px 32px; } }

    .principles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    @media (max-width: 900px) { .principles-grid { grid-template-columns: 1fr; } }

    .principle-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 36px 32px;
    }
    .principle-no {
        font-family: Syne, sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 16px;
    }
    .principle-title { font-size: 22px; font-weight: 700; margin-bottom: 12px; }
    .principle-desc { font-size: 15px; color: var(--text-muted); line-height: 1.7; }

    /* ── Pilar (band navy) ── */
    .pillars { max-width: 1180px; margin: 0 auto; padding: 64px 40px; }
    @media (max-width: 640px) { .pillars { padding: 40px 24px; } }

    .pillars-band {
        background: var(--surface-deep);
        border-radius: 20px;
        padding: 64px 60px;
    }
    @media (max-width: 640px) { .pillars-band { padding: 40px 28px; } }

    .pillars-band .eyebrow { margin-bottom: 40px; }

    .pillars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 52px; }
    @media (max-width: 900px) { .pillars-grid { grid-template-columns: 1fr; gap: 32px; } }

    /* Dividers sit between columns only — the rule would dangle once the grid
       collapses to a single column. */
    .pillar + .pillar {
        border-left: 1px solid var(--surface-deep-border);
        padding-left: 52px;
    }
    @media (max-width: 900px) {
        .pillar + .pillar {
            border-left: none;
            border-top: 1px solid var(--surface-deep-border);
            padding-left: 0;
            padding-top: 32px;
        }
    }

    .pillar-title {
        font-size: 26px;
        font-weight: 700;
        color: var(--surface-deep-text);
        margin-bottom: 14px;
    }
    .pillar-desc { font-size: 15px; color: var(--surface-deep-muted); line-height: 1.75; }

    /* ── Tim ── */
    .team { max-width: 1180px; margin: 0 auto; padding: 40px 40px; }
    @media (max-width: 640px) { .team { padding: 32px 24px; } }

    .team-head { margin-bottom: 36px; }
    .team-heading { font-size: clamp(1.625rem, 3.5vw, 30px); font-weight: 700; }

    .team-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    @media (max-width: 900px) { .team-grid { grid-template-columns: 1fr; } }

    .team-card {
        display: flex;
        gap: 20px;
        align-items: flex-start;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 28px 30px;
        transition: border-color 0.25s, box-shadow 0.25s;
    }
    .team-card:hover { border-color: #b8d3ef; box-shadow: var(--shadow-card); }
    html.dark .team-card:hover { border-color: var(--accent); }

    .avatar {
        width: 52px; height: 52px;
        border-radius: 12px;
        background: var(--accent-soft);
        color: var(--accent);
        display: flex; align-items: center; justify-content: center;
        font-family: Syne, sans-serif;
        font-size: 17px; font-weight: 700;
        letter-spacing: 0.02em;
        flex-shrink: 0;
    }
    .team-name { font-size: 17px; font-weight: 700; margin-bottom: 4px; line-height: 1.3; }
    .team-role {
        font-size: 12px;
        font-weight: 600;
        color: var(--accent);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 10px;
    }
    .team-desc { font-size: 14.5px; color: var(--text-muted); line-height: 1.7; }
</style>

<script>
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
