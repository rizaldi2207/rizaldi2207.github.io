---
import Layout from "../layouts/Layout.astro";

const team = [
    {
        name: "Thomson Rihad Dodi Malau",
        role: "Security Engineer",
        description: "Security Engineer dengan pengalaman 6+ tahun dalam membangun infrastruktur yang aman dan scalable.",
    },
    {
        name: "Zahra Nabila Putri",
        role: "Application Security Specialist",
        description: "Spesialis keamanan aplikasi yang fokus pada penerapan best practices secure coding dan vulnerability management.",
    },
    {
        name: "Rizaldi Sanjaya",
        role: "DevSecOps Engineer",
        description: "Membangun security automation pada CI/CD pipeline untuk aplikasi modern.",
    },
    {
        name: "Yunita Ariswanti Purnama Putri",
        role: "Content Writer",
        description: "Technical writer yang mengubah konsep kompleks menjadi konten yang mudah dipahami.",
    },
];

const missions = [
    { icon: "📚", title: "Edukasi Berkualitas", desc: "Konten mendalam dan praktis tentang keamanan aplikasi dalam bahasa Indonesia yang mudah dipahami." },
    { icon: "🤝", title: "Membangun Komunitas", desc: "Ruang kolaborasi antara Security Engineer dan Developer untuk berbagi pengalaman dan best practices." },
    { icon: "🔒", title: "Meningkatkan Keamanan", desc: "Mendorong secure coding dan security-first mindset di setiap tahap pengembangan aplikasi." },
];

function initials(name: string) {
    return name.split(" ").slice(0, 2).map((n) => n[0]).join("");
}
---

<Layout
    title="Tentang Kami — Appsecmonarch"
    description="Membangun ekosistem di mana Security Engineer dan Developer bekerja bersama untuk menciptakan aplikasi yang aman dan tangguh."
>
    <!-- ── Hero ── -->
    <section class="about-hero fade-in-up">
        <div class="code-label">// ABOUT_US</div>
        <h1 class="hero-heading">
            Tentang <em class="em-accent">Appsecmonarch</em>
        </h1>
        <p class="hero-sub">
            Membangun ekosistem di mana Security Engineer dan Developer bekerja
            bersama untuk menciptakan aplikasi yang aman dan tangguh.
        </p>
    </section>

    <!-- ── Story section ── -->
    <section class="story-section">
        <div class="story-inner">
            <!-- Code block -->
            <div class="code-block fade-in-up">
                <div class="terminal-chrome">
                    <span class="dot" style="background:#ff5f57"></span>
                    <span class="dot" style="background:#febc2e"></span>
                    <span class="dot" style="background:#28c840"></span>
                    <span class="terminal-title">about.ts</span>
                </div>
                <div class="code-line"><span class="c-kw">const </span><span class="c-var">appsecmonarch</span><span class="c-pu"> = &#123;</span></div>
                <div class="code-line"><span class="c-pu">&#160;&#160;</span><span class="c-key">visi</span><span class="c-pu">: </span><span class="c-str">"Security-first culture"</span><span class="c-pu">,</span></div>
                <div class="code-line"><span class="c-pu">&#160;&#160;</span><span class="c-key">misi</span><span class="c-pu">: </span><span class="c-str">"Edukasi AppSec Indonesia"</span><span class="c-pu">,</span></div>
                <div class="code-line"><span class="c-pu">&#160;&#160;</span><span class="c-key">since</span><span class="c-pu">: </span><span class="c-num">2025</span><span class="c-pu">,</span></div>
                <div class="code-line"><span class="c-pu">&#160;&#160;</span><span class="c-key">bahasa</span><span class="c-pu">: </span><span class="c-str">"Indonesia"</span><span class="c-pu">,</span></div>
                <div class="code-line"><span class="c-pu">&#160;&#160;</span><span class="c-key">status</span><span class="c-pu">: </span><span class="c-grn">"active"</span><span class="c-pu">,</span></div>
                <div class="code-line"><span class="c-pu">&#125;;</span></div>
            </div>

            <!-- Story text -->
            <div class="story-text fade-in-up">
                <div class="code-label">// OUR_STORY</div>
                <h2 class="section-heading">
                    Tentang <em class="em-accent">Kami</em>
                </h2>
                <p class="body-text">
                    Appsecmonarch adalah komunitas yang didirikan dengan visi untuk menjembatani kesenjangan antara keamanan dan pengembangan aplikasi.
                </p>
                <p class="body-text" style="margin-top:1rem;">
                    Kami percaya bahwa keamanan bukan sekadar fitur tambahan, melainkan fondasi dari setiap aplikasi yang berkualitas.
                </p>
                <p class="body-text" style="margin-top:1rem;">
                    Melalui artikel, tutorial, dan studi kasus, kami berkomitmen memberdayakan developer dan security engineer di Indonesia.
                </p>
            </div>
        </div>
    </section>

    <!-- ── Missions ── -->
    <section class="missions-section">
        <div class="missions-inner">
            <div class="section-header fade-in-up">
                <div class="code-label">// MISSION</div>
                <h2 class="section-heading">Misi <em class="em-accent">Kami</em></h2>
            </div>
            <div class="missions-grid">
                {missions.map(({ icon, title, desc }) => (
                    <div class="mission-card fade-in-up">
                        <div class="mission-icon">{icon}</div>
                        <h3 class="mission-title">{title}</h3>
                        <p class="mission-desc">{desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── Team ── -->
    <section class="team-section">
        <div class="team-inner">
            <div class="section-header fade-in-up">
                <div class="code-label">// TEAM</div>
                <h2 class="section-heading">Tim <em class="em-accent">Kami</em></h2>
            </div>
            <div class="team-grid">
                {team.map((member) => (
                    <div class="team-card fade-in-up">
                        <div class="avatar">{initials(member.name)}</div>
                        <div class="team-body">
                            <h3 class="team-name">{member.name}</h3>
                            <p class="team-role">{member.role}</p>
                            <p class="team-desc">{member.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── CTA ── -->
    <section class="cta-section fade-in-up">
        <div class="cta-inner">
            <h2 class="cta-heading">Tertarik Bergabung?</h2>
            <p class="cta-sub">
                Mari bersama-sama membangun ekosistem keamanan aplikasi yang lebih baik.
            </p>
            <a href="/contact" class="btn-primary">Hubungi Kami</a>
        </div>
    </section>
</Layout>

<style>
    .code-label {
        font-family: "JetBrains Mono", monospace; font-size: 0.7rem;
        color: #00d4ff; letter-spacing: 0.1em; opacity: 0.7; margin-bottom: 0.75rem;
    }
    .section-heading {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: clamp(1.75rem, 3.5vw, 2.25rem);
        color: var(--text); line-height: 1.2; margin-bottom: 0;
    }
    .em-accent { font-style: italic; color: #00d4ff; }
    html:not(.dark) .em-accent { color: #003377; }
    .body-text { font-size: 0.9375rem; color: var(--text-muted); line-height: 1.75; }

    .btn-primary {
        background: #00d4ff; color: #0a0e1a;
        padding: 0.8125rem 2rem; border-radius: 8px;
        font-weight: 600; font-size: 0.9375rem;
        text-decoration: none; transition: opacity 0.2s; display: inline-block;
    }
    html:not(.dark) .btn-primary { background: #003377; color: #fff; }
    .btn-primary:hover { opacity: 0.88; }

    /* ── Hero ── */
    .about-hero {
        max-width: 1280px; margin: 0 auto;
        padding: 4rem 2.5rem 5rem; text-align: center;
    }
    @media (max-width: 640px) { .about-hero { padding: 3rem 1.5rem; } }

    .hero-heading {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: clamp(2.5rem, 5vw, 3.75rem);
        line-height: 1.1; color: var(--text); margin-bottom: 1.25rem;
    }
    .hero-sub {
        font-size: 1.125rem; color: var(--text-muted);
        max-width: 560px; margin: 0 auto; line-height: 1.7;
    }

    /* ── Story ── */
    .story-section { background: var(--bg-secondary); padding: 5rem 0; }
    .story-inner {
        max-width: 1280px; margin: 0 auto; padding: 0 2.5rem;
        display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
    }
    @media (max-width: 900px) { .story-inner { grid-template-columns: 1fr; gap: 2rem; padding: 0 1.5rem; } }

    .code-block {
        background: #0d1320;
        border: 1px solid rgba(0,212,255,0.2);
        border-radius: 12px; padding: 1.75rem;
        font-family: "JetBrains Mono", monospace; font-size: 0.8125rem; line-height: 2;
    }
    html:not(.dark) .code-block { background: #1a2235; }

    .terminal-chrome { display: flex; align-items: center; gap: 6px; margin-bottom: 1.25rem; }
    .dot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }
    .terminal-title { margin-left: 8px; color: #8b9cbb; font-size: 0.7rem; }
    .code-line { display: block; }
    .c-kw  { color: #7c8bac; }
    .c-var { color: #00d4ff; }
    .c-pu  { color: #7c8bac; }
    .c-key { color: #22d3a5; }
    .c-str { color: #f59e0b; }
    .c-num { color: #a78bfa; }
    .c-grn { color: #22d3a5; }

    /* ── Missions ── */
    .missions-section { max-width: 1280px; margin: 0 auto; padding: 5rem 2.5rem; }
    @media (max-width: 640px) { .missions-section { padding: 4rem 1.5rem; } }

    .section-header { text-align: center; margin-bottom: 3rem; }
    .missions-grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
    }
    @media (max-width: 900px) { .missions-grid { grid-template-columns: 1fr; } }

    .mission-card {
        background: var(--card-bg);
        border: 2px solid var(--border);
        border-radius: 12px; padding: 2rem;
        transition: border-color 0.25s, transform 0.25s;
    }
    .mission-card:hover { border-color: #00d4ff; transform: translateY(-4px); }
    html:not(.dark) .mission-card:hover { border-color: #003377; }

    .mission-icon {
        width: 52px; height: 52px; border-radius: 12px;
        background: rgba(0,212,255,0.08);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; margin-bottom: 1.25rem;
    }
    .mission-title {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: 1.125rem; color: var(--text); margin-bottom: 0.625rem;
    }
    .mission-desc { font-size: 0.9375rem; color: var(--text-muted); line-height: 1.65; }

    /* ── Team ── */
    .team-section { background: var(--bg-secondary); padding: 5rem 0; }
    .team-inner { max-width: 1280px; margin: 0 auto; padding: 0 2.5rem; }
    @media (max-width: 640px) { .team-inner { padding: 0 1.5rem; } }

    .team-grid {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
    }
    @media (max-width: 900px) { .team-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 500px) { .team-grid { grid-template-columns: 1fr; } }

    .team-card {
        background: var(--card-bg); border: 1px solid var(--border);
        border-radius: 12px; overflow: hidden;
        transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    }
    .team-card:hover {
        border-color: #00d4ff;
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(0,212,255,0.08);
    }
    html:not(.dark) .team-card:hover { border-color: #003377; box-shadow: 0 8px 32px rgba(0,51,119,0.08); }

    .avatar {
        aspect-ratio: 1;
        background: linear-gradient(135deg, #0d1a33 0%, #1a2235 100%);
        display: flex; align-items: center; justify-content: center;
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: 2.5rem; color: #00d4ff; letter-spacing: -0.02em;
        border-bottom: 1px solid rgba(0,212,255,0.08);
    }
    html:not(.dark) .avatar {
        background: linear-gradient(135deg, #eff6ff 0%, #e0f2fe 100%);
        border-bottom-color: #e5e7eb;
    }

    .team-body { padding: 1.5rem; }
    .team-name {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: 1.0625rem; color: var(--text); margin-bottom: 0.25rem;
    }
    .team-role {
        font-family: "JetBrains Mono", monospace; font-size: 0.7rem;
        color: #00d4ff; letter-spacing: 0.05em; margin-bottom: 0.875rem;
    }
    .team-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; }

    /* ── CTA ── */
    .cta-section { max-width: 1280px; margin: 0 auto; padding: 5rem 2.5rem; }
    @media (max-width: 640px) { .cta-section { padding: 4rem 1.5rem; } }

    .cta-inner {
        background: linear-gradient(135deg, #eff6ff 0%, #f0fdfa 100%);
        border: 1px solid rgba(0,51,119,0.1);
        border-radius: 16px; padding: 4rem; text-align: center;
    }
    html.dark .cta-inner {
        background: linear-gradient(135deg, #0d1a33 0%, #111827 100%);
        border-color: rgba(0,212,255,0.15);
    }
    @media (max-width: 640px) { .cta-inner { padding: 2.5rem 1.5rem; } }

    .cta-heading {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: 2rem; color: var(--text); margin-bottom: 0.875rem;
    }
    .cta-sub {
        font-size: 1.0625rem; color: var(--text-muted);
        max-width: 400px; margin: 0 auto 2rem;
    }
</style>

<script>
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
