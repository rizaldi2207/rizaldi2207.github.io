---
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
---

<Layout
    title="Blog — Appsecmonarch"
    description="Tulisan seputar application security, DevSecOps, dan pengembangan aman."
>
    <div class="blog-page">
        <!-- Header -->
        <div class="page-header fade-in-up">
            <div class="code-label">// BLOG_POSTS</div>
            <h1 class="page-title">
                Semua <em class="em-accent">Artikel</em>
            </h1>
            <p class="page-sub">
                Tulisan seputar application security, DevSecOps, dan pengembangan aman.
            </p>
        </div>

        <!-- Tag filter -->
        <div class="tag-filter fade-in-up" id="tag-filter">
            <button class="tag-btn active" data-tag="all">All</button>
            {allTags.map((tag) => (
                <button class="tag-btn" data-tag={tag}>#{tag}</button>
            ))}
        </div>

        <!-- Posts list -->
        <div class="posts-list" id="posts-list">
            {posts.map((post) => {
                const dateStr = post.data.pubDate.toLocaleDateString("id-ID", {
                    day: "numeric", month: "long", year: "numeric",
                });
                return (
                    <a
                        href={`/blog/${post.slug}`}
                        class="post-item"
                        data-tags={(post.data.tags ?? []).join(",")}
                    >
                        <div class="post-thumb">
                            {post.data.heroImage
                                ? <img src={post.data.heroImage} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;border-radius:10px;" />
                                : <span class="thumb-placeholder">[ image ]</span>
                            }
                        </div>
                        <div class="post-body">
                            <div class="post-tags">
                                {(post.data.tags ?? []).map((tag: string) => (
                                    <span class="tag">#{tag}</span>
                                ))}
                            </div>
                            <h2 class="post-title">{post.data.title}</h2>
                            <p class="post-desc">{post.data.description}</p>
                            <span class="post-date">{dateStr}</span>
                        </div>
                    </a>
                );
            })}
        </div>

        <!-- Empty state -->
        <div class="empty-state" id="empty-state">
            <span class="empty-icon">[ 0 results ]</span>
            <p>Tidak ada artikel untuk tag ini.</p>
        </div>

        <!-- Pagination -->
        <nav class="pagination" id="pagination" aria-label="Navigasi halaman"></nav>
    </div>
</Layout>

<style>
    .blog-page {
        max-width: 1280px; margin: 0 auto;
        padding: 4rem 2.5rem 6rem;
    }
    @media (max-width: 640px) { .blog-page { padding: 3rem 1.5rem 5rem; } }

    .code-label {
        font-family: "JetBrains Mono", monospace; font-size: 0.7rem;
        color: #00d4ff; letter-spacing: 0.1em; opacity: 0.7; margin-bottom: 0.75rem;
    }
    html:not(.dark) .code-label { color: #003377; }

    .page-title {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: clamp(2rem, 4vw, 3rem); color: var(--text);
        margin-bottom: 1rem; line-height: 1.1;
    }
    .em-accent { font-style: italic; color: #00d4ff; }
    html:not(.dark) .em-accent { color: #003377; }

    .page-sub { font-size: 1.0625rem; color: var(--text-muted); margin-bottom: 3rem; }

    /* Tag filter */
    .tag-filter { display: flex; gap: 0.625rem; flex-wrap: wrap; margin-bottom: 2.5rem; }

    .tag-btn {
        font-family: "JetBrains Mono", monospace; font-size: 0.75rem;
        padding: 0.35rem 0.875rem; border-radius: 6px; cursor: pointer;
        background: var(--bg-secondary); color: var(--text-muted);
        border: 1px solid var(--border);
        transition: all 0.2s;
    }
    .tag-btn:hover { border-color: #00d4ff; color: #00d4ff; }
    html:not(.dark) .tag-btn:hover { border-color: #003377; color: #003377; }
    .tag-btn.active {
        background: #00d4ff; color: #0a0e1a; border-color: #00d4ff;
    }
    html:not(.dark) .tag-btn.active { background: #003377; color: #fff; border-color: #003377; }

    /* Posts list */
    .posts-list {
        display: flex; flex-direction: column;
        transition: opacity 0.18s ease, transform 0.18s ease;
    }
    .posts-list.changing { opacity: 0; transform: translateY(6px); }

    .post-item {
        display: grid; grid-template-columns: 200px 1fr;
        gap: 2rem; align-items: start;
        padding: 2rem 0;
        border-bottom: 1px solid var(--border);
        text-decoration: none; color: var(--text);
    }
    .post-item.hidden { display: none; }
    @media (max-width: 640px) { .post-item { grid-template-columns: 1fr; } }

    .post-thumb {
        width: 100%; aspect-ratio: 4/3; border-radius: 10px;
        background: linear-gradient(135deg, #1a2235 0%, #0d1320 100%);
        border: 1px solid var(--border);
        display: flex; align-items: center; justify-content: center;
        overflow: hidden; transition: border-color 0.2s;
    }
    html:not(.dark) .post-thumb { background: linear-gradient(135deg, #e2e8f0 0%, #f1f5f9 100%); }
    .post-item:hover .post-thumb { border-color: rgba(0,212,255,0.25); }

    .thumb-placeholder {
        font-family: "JetBrains Mono", monospace; font-size: 0.65rem;
        color: #4a5568;
    }
    html:not(.dark) .thumb-placeholder { color: #94a3b8; }

    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.625rem; }

    .tag {
        font-family: "JetBrains Mono", monospace; font-size: 0.7rem;
        color: #00d4ff; background: rgba(0,212,255,0.08);
        padding: 0.2rem 0.6rem; border-radius: 4px;
    }
    html:not(.dark) .tag { color: #003377; background: rgba(0,51,119,0.08); }

    .post-title {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: 1.375rem; line-height: 1.3; color: var(--text);
        margin-bottom: 0.625rem; transition: color 0.2s;
    }
    .post-item:hover .post-title { color: #00d4ff; }
    html:not(.dark) .post-item:hover .post-title { color: #003377; }

    .post-desc {
        font-size: 0.9375rem; color: var(--text-muted);
        line-height: 1.65; margin-bottom: 1rem;
    }
    .post-date { font-size: 0.8rem; color: var(--text-dim); }

    /* Empty state */
    .empty-state {
        display: none;
        flex-direction: column; align-items: center; justify-content: center;
        gap: 0.75rem; padding: 4rem 0; text-align: center;
    }
    .empty-state.visible { display: flex; }
    .empty-icon {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.875rem; color: var(--text-dim);
    }
    .empty-state p { font-size: 1rem; color: var(--text-muted); }

    /* ── Pagination ── */
    .pagination {
        display: flex; align-items: center; justify-content: center;
        gap: 0.375rem; padding-top: 3rem; flex-wrap: wrap;
    }

    .page-btn {
        font-family: "JetBrains Mono", monospace; font-size: 0.8125rem;
        min-width: 36px; height: 36px; padding: 0 0.5rem;
        border-radius: 6px; cursor: pointer;
        background: var(--bg-secondary); color: var(--text-muted);
        border: 1px solid var(--border);
        display: inline-flex; align-items: center; justify-content: center;
        transition: all 0.2s;
        user-select: none;
    }
    .page-btn:hover:not(:disabled) { border-color: #00d4ff; color: #00d4ff; }
    html:not(.dark) .page-btn:hover:not(:disabled) { border-color: #003377; color: #003377; }
    .page-btn.active {
        background: #00d4ff; color: #0a0e1a; border-color: #00d4ff;
        font-weight: 600;
    }
    html:not(.dark) .page-btn.active { background: #003377; color: #fff; border-color: #003377; }
    .page-btn:disabled { opacity: 0.3; cursor: not-allowed; }

    .page-ellipsis {
        font-family: "JetBrains Mono", monospace; font-size: 0.8125rem;
        color: var(--text-dim); padding: 0 0.25rem;
    }
</style>

<script>
    const POSTS_PER_PAGE = 5;

    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const postItems = Array.from(document.querySelectorAll<HTMLElement>('.post-item'));
    const listEl    = document.getElementById('posts-list')!;
    const paginationEl = document.getElementById('pagination')!;
    const emptyEl   = document.getElementById('empty-state')!;

    let currentTag  = 'all';
    let currentPage = 1;

    function getFiltered(): HTMLElement[] {
        if (currentTag === 'all') return postItems;
        return postItems.filter(item => {
            const tags = (item.dataset.tags ?? '').split(',');
            return tags.includes(currentTag);
        });
    }

    function renderPage() {
        const filtered  = getFiltered();
        const totalPages = Math.ceil(filtered.length / POSTS_PER_PAGE);
        const start = (currentPage - 1) * POSTS_PER_PAGE;
        const end   = start + POSTS_PER_PAGE;

        postItems.forEach(item => item.classList.add('hidden'));
        filtered.slice(start, end).forEach(item => item.classList.remove('hidden'));

        // Empty state
        emptyEl.classList.toggle('visible', filtered.length === 0);

        renderPagination(totalPages);
    }

    function renderPagination(totalPages: number) {
        if (totalPages <= 1) { paginationEl.innerHTML = ''; return; }

        const btns: string[] = [];

        // Prev
        btns.push(
            `<button class="page-btn" data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''} aria-label="Halaman sebelumnya">&#8592;</button>`
        );

        // Page numbers with ellipsis for large sets
        const range = pageRange(currentPage, totalPages);
        range.forEach(p => {
            if (p === '...') {
                btns.push(`<span class="page-ellipsis">…</span>`);
            } else {
                btns.push(
                    `<button class="page-btn ${p === currentPage ? 'active' : ''}" data-page="${p}" aria-label="Halaman ${p}" aria-current="${p === currentPage ? 'page' : 'false'}">${p}</button>`
                );
            }
        });

        // Next
        btns.push(
            `<button class="page-btn" data-page="${currentPage + 1}" ${currentPage === totalPages ? 'disabled' : ''} aria-label="Halaman berikutnya">&#8594;</button>`
        );

        paginationEl.innerHTML = btns.join('');

        paginationEl.querySelectorAll<HTMLButtonElement>('.page-btn:not([disabled])').forEach(btn => {
            btn.addEventListener('click', () => {
                const next = parseInt(btn.dataset.page ?? '1');
                if (next === currentPage) return;
                goToPage(next);
            });
        });
    }

    function pageRange(current: number, total: number): (number | '...')[] {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        const pages: (number | '...')[] = [];
        pages.push(1);
        if (current > 3) pages.push('...');
        for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
            pages.push(i);
        }
        if (current < total - 2) pages.push('...');
        pages.push(total);
        return pages;
    }

    function goToPage(page: number) {
        currentPage = page;
        listEl.classList.add('changing');
        setTimeout(() => {
            renderPage();
            listEl.classList.remove('changing');
            window.scrollTo({ top: listEl.getBoundingClientRect().top + window.scrollY - 120, behavior: 'smooth' });
        }, 180);
    }

    // Tag filter
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const tag = btn.dataset.tag ?? 'all';
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentTag  = tag;
            currentPage = 1;
            listEl.classList.add('changing');
            setTimeout(() => {
                renderPage();
                listEl.classList.remove('changing');
            }, 180);
        });
    });

    // Initial render
    renderPage();

    // Scroll fade-in for header + tag filter
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0 });
    fadeEls.forEach(el => observer.observe(el));
</script>
