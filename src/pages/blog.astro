---
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
---

<Layout
    title="Blog — Appsecmonarch"
    description="Tulisan seputar application security, DevSecOps, dan pengembangan aman."
>
    <div class="blog-page">
        <!-- Header -->
        <div class="page-header fade-in-up">
            <div class="code-label">// BLOG_POSTS</div>
            <h1 class="page-title">
                Semua <em class="em-accent">Artikel</em>
            </h1>
            <p class="page-sub">
                Tulisan seputar application security, DevSecOps, dan pengembangan aman.
            </p>
        </div>

        <!-- Tag filter -->
        <div class="tag-filter fade-in-up" id="tag-filter">
            <button class="tag-btn active" data-tag="all">All</button>
            {allTags.map((tag) => (
                <button class="tag-btn" data-tag={tag}>#{tag}</button>
            ))}
        </div>

        <!-- Posts list -->
        <div class="posts-list" id="posts-list">
            {posts.map((post) => {
                const dateStr = post.data.pubDate.toLocaleDateString("id-ID", {
                    day: "numeric", month: "long", year: "numeric",
                });
                return (
                    <a
                        href={`/blog/${post.slug}`}
                        class="post-item"
                        data-tags={(post.data.tags ?? []).join(",")}
                    >
                        <div class="post-thumb">
                            {post.data.heroImage
                                ? <img src={post.data.heroImage} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;border-radius:10px;" />
                                : <span class="thumb-placeholder">[ image ]</span>
                            }
                        </div>
                        <div class="post-body">
                            <div class="post-tags">
                                {(post.data.tags ?? []).map((tag: string) => (
                                    <span class="tag">#{tag}</span>
                                ))}
                            </div>
                            <h2 class="post-title">{post.data.title}</h2>
                            <p class="post-desc">{post.data.description}</p>
                            <span class="post-date">{dateStr}</span>
                        </div>
                    </a>
                );
            })}
        </div>
    </div>
</Layout>

<style>
    .blog-page {
        max-width: 1280px; margin: 0 auto;
        padding: 4rem 2.5rem 6rem;
    }
    @media (max-width: 640px) { .blog-page { padding: 3rem 1.5rem 5rem; } }

    .code-label {
        font-family: "JetBrains Mono", monospace; font-size: 0.7rem;
        color: #00d4ff; letter-spacing: 0.1em; opacity: 0.7; margin-bottom: 0.75rem;
    }

    .page-title {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: clamp(2rem, 4vw, 3rem); color: var(--text);
        margin-bottom: 1rem; line-height: 1.1;
    }
    .em-accent { font-style: italic; color: #00d4ff; }
    html:not(.dark) .em-accent { color: #003377; }

    .page-sub { font-size: 1.0625rem; color: var(--text-muted); margin-bottom: 3rem; }

    /* Tag filter */
    .tag-filter { display: flex; gap: 0.625rem; flex-wrap: wrap; margin-bottom: 2.5rem; }

    .tag-btn {
        font-family: "JetBrains Mono", monospace; font-size: 0.75rem;
        padding: 0.35rem 0.875rem; border-radius: 6px; cursor: pointer;
        background: var(--bg-secondary); color: var(--text-muted);
        border: 1px solid var(--border);
        transition: all 0.2s;
    }
    .tag-btn:hover { border-color: #00d4ff; color: #00d4ff; }
    html:not(.dark) .tag-btn:hover { border-color: #003377; color: #003377; }
    .tag-btn.active {
        background: #00d4ff; color: #0a0e1a; border-color: #00d4ff;
    }
    html:not(.dark) .tag-btn.active { background: #003377; color: #fff; border-color: #003377; }

    /* Posts */
    .posts-list { display: flex; flex-direction: column; }

    .post-item {
        display: grid; grid-template-columns: 200px 1fr;
        gap: 2rem; align-items: start;
        padding: 2rem 0;
        border-bottom: 1px solid var(--border);
        text-decoration: none; color: var(--text);
        transition: opacity 0.2s;
    }
    .post-item.hidden { display: none; }
    @media (max-width: 640px) { .post-item { grid-template-columns: 1fr; } }

    .post-thumb {
        width: 100%; aspect-ratio: 4/3; border-radius: 10px;
        background: linear-gradient(135deg, #1a2235 0%, #0d1320 100%);
        border: 1px solid var(--border);
        display: flex; align-items: center; justify-content: center;
        overflow: hidden; transition: border-color 0.2s;
    }
    html:not(.dark) .post-thumb { background: linear-gradient(135deg, #e2e8f0 0%, #f1f5f9 100%); }
    .post-item:hover .post-thumb { border-color: rgba(0,212,255,0.25); }

    .thumb-placeholder {
        font-family: "JetBrains Mono", monospace; font-size: 0.65rem;
        color: #4a5568;
    }
    html:not(.dark) .thumb-placeholder { color: #94a3b8; }

    .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.625rem; }

    .tag {
        font-family: "JetBrains Mono", monospace; font-size: 0.7rem;
        color: #00d4ff; background: rgba(0,212,255,0.08);
        padding: 0.2rem 0.6rem; border-radius: 4px;
    }

    .post-title {
        font-family: "IBM Plex Serif", serif; font-weight: 700;
        font-size: 1.375rem; line-height: 1.3; color: var(--text);
        margin-bottom: 0.625rem; transition: color 0.2s;
    }
    .post-item:hover .post-title { color: #00d4ff; }
    html:not(.dark) .post-item:hover .post-title { color: #003377; }

    .post-desc {
        font-size: 0.9375rem; color: var(--text-muted);
        line-height: 1.65; margin-bottom: 1rem;
    }
    .post-date { font-size: 0.8rem; color: var(--text-dim); }
</style>

<script>
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const postItems = document.querySelectorAll<HTMLElement>('.post-item');

    filterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
            const tag = btn.dataset.tag ?? 'all';

            filterBtns.forEach((b) => b.classList.remove('active'));
            btn.classList.add('active');

            postItems.forEach((item) => {
                if (tag === 'all') {
                    item.classList.remove('hidden');
                } else {
                    const tags = (item.dataset.tags ?? '').split(',');
                    item.classList.toggle('hidden', !tags.includes(tag));
                }
            });
        });
    });

    // Scroll fade-in
    const fadeEls = document.querySelectorAll('.fade-in-up');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('visible');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });
    fadeEls.forEach((el) => observer.observe(el));
</script>
