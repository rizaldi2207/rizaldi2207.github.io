---
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Only tags that actually group something earn a chip. Every tag would mean 21
// chips over three rows for 6 posts, most of them leading to a single article —
// noise rather than a filter. The full list stays reachable at /tags.
const MIN_POSTS_PER_CHIP = 2;

const tagCounts = posts.reduce((acc, p) => {
    (p.data.tags ?? []).forEach((t) => { acc[t] = (acc[t] ?? 0) + 1; });
    return acc;
}, {} as Record<string, number>);

const filterTags = Object.entries(tagCounts)
    .filter(([, n]) => n >= MIN_POSTS_PER_CHIP)
    .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
    .map(([tag]) => tag);

const hiddenTagCount = Object.keys(tagCounts).length - filterTags.length;

// The newest post headlines the page. The grid drops it while "Semua" is active
// so it never appears twice; filtering returns it to the pool.
const featured = posts[0];

const fmtDate = (d: Date) =>
    d.toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" });
---

<Layout
    title="Blog — Appsecmonarch"
    description="Tulisan seputar application security, DevSecOps, dan pengembangan aman. Satu topik per tulisan."
>
    <!-- ══════════ HEADER ══════════ -->
    <section class="blog-head">
        <div class="blog-head-inner">
            <p class="eyebrow">Blog</p>
            <h1 class="blog-title">Tulisan &amp; catatan security</h1>
            <p class="blog-sub">
                Satu topik per tulisan. Ambil yang kamu butuhkan hari ini,
                simpan sisanya untuk nanti.
            </p>

            <div class="tag-filter" id="tag-filter">
                <button class="tag-btn active" data-tag="all">Semua</button>
                {filterTags.map((tag) => (
                    <button class="tag-btn" data-tag={tag}>{tag}</button>
                ))}
                {hiddenTagCount > 0 && (
                    <a href="/tags" class="tag-btn tag-btn-more">
                        +{hiddenTagCount} topik lain →
                    </a>
                )}
            </div>
        </div>
    </section>

    <!-- ══════════ UNGGULAN ══════════ -->
    {featured && (
        <section class="featured-wrap" id="featured" data-slug={featured.slug}>
            <a href={`/blog/${featured.slug}`} class="featured-card">
                <div class="featured-media">
                    {featured.data.heroImage && (
                        <img src={featured.data.heroImage} alt="" class="featured-img" />
                    )}
                </div>
                <div class="featured-body">
                    <div class="featured-badges">
                        <span class="badge-featured">Unggulan</span>
                        {featured.data.tags?.[0] && (
                            <span class="badge-cat">{featured.data.tags[0]}</span>
                        )}
                    </div>
                    <h2 class="featured-title">{featured.data.title}</h2>
                    <p class="featured-excerpt">{featured.data.description}</p>
                    <div class="featured-foot">
                        <p class="featured-meta">
                            Appsecmonarch · {fmtDate(featured.data.pubDate)}
                        </p>
                        <span class="link-accent">Baca selengkapnya →</span>
                    </div>
                </div>
            </a>
        </section>
    )}

    <!-- ══════════ GRID ══════════ -->
    <section class="grid-wrap">
        <div class="post-grid" id="posts-grid">
            {posts.map((post) => (
                <a
                    href={`/blog/${post.slug}`}
                    class="post-card"
                    data-slug={post.slug}
                    data-tags={(post.data.tags ?? []).join(",")}
                >
                    <div class="post-media">
                        {post.data.heroImage && (
                            <img src={post.data.heroImage} alt="" class="post-img" />
                        )}
                    </div>
                    <div class="post-body">
                        {post.data.tags?.[0] && (
                            <span class="post-cat">{post.data.tags[0]}</span>
                        )}
                        <h3 class="post-title">{post.data.title}</h3>
                        <p class="post-excerpt">{post.data.description}</p>
                        <p class="post-meta">Appsecmonarch · {fmtDate(post.data.pubDate)}</p>
                    </div>
                </a>
            ))}
        </div>

        <div class="empty-state" id="empty-state">
            <p class="empty-title">Belum ada tulisan untuk topik ini.</p>
            <p class="empty-sub">Coba pilih topik lain, atau lihat semua tulisan.</p>
        </div>

        <nav class="pagination" id="pagination" aria-label="Navigasi halaman"></nav>
    </section>
</Layout>

<style>
    .link-accent {
        font-size: 15px;
        font-weight: 600;
        color: var(--accent);
        transition: color 0.2s;
    }

    /* ── Header ── */
    .blog-head {
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
    }
    .blog-head-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 72px 40px 60px;
    }
    @media (max-width: 640px) { .blog-head-inner { padding: 48px 24px 40px; } }

    .blog-title {
        font-size: clamp(2rem, 5vw, 48px);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 18px;
    }
    .blog-sub {
        font-size: 17px;
        color: var(--text-muted);
        line-height: 1.7;
        max-width: 640px;
        margin-bottom: 34px;
    }

    /* ── Filter ── */
    .tag-filter { display: flex; gap: 10px; flex-wrap: wrap; }
    .tag-btn {
        background: var(--card-bg);
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        padding: 9px 18px;
        font-family: inherit;
        font-size: 13.5px;
        font-weight: 500;
        color: var(--text-body);
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s, color 0.2s;
    }
    .tag-btn:hover { border-color: var(--accent); }
    .tag-btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: var(--accent-contrast);
        font-weight: 600;
    }

    /* Escape hatch to the full topic list — a link, not a filter, so it never
       takes the active state. */
    .tag-btn-more {
        background: transparent;
        border-style: dashed;
        color: var(--accent);
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

    /* ── Unggulan ── */
    .featured-wrap { max-width: 1180px; margin: 0 auto; padding: 56px 40px 40px; }
    @media (max-width: 640px) { .featured-wrap { padding: 40px 24px 24px; } }
    .featured-wrap.hidden { display: none; }

    .featured-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        display: flex;
        align-items: stretch;
        text-decoration: none;
        transition: box-shadow 0.25s, border-color 0.25s;
    }
    .featured-card:hover {
        box-shadow: 0 18px 44px rgba(0, 24, 64, 0.1);
        border-color: #b8d3ef;
    }
    html.dark .featured-card:hover {
        border-color: var(--accent);
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.4);
    }
    @media (max-width: 900px) { .featured-card { flex-direction: column; } }

    .featured-media {
        flex: 1.05;
        background: var(--media-bg);
        min-height: 380px;
        position: relative;
    }
    @media (max-width: 900px) { .featured-media { min-height: 0; aspect-ratio: 16/9; } }
    .featured-img {
        position: absolute;
        inset: 0;
        width: 100%; height: 100%;
        object-fit: cover;
    }

    .featured-body {
        flex: 1;
        padding: 52px 50px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    @media (max-width: 640px) { .featured-body { padding: 32px 24px; } }

    .featured-badges { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .badge-featured {
        display: inline-flex;
        background: var(--surface-deep);
        color: var(--surface-deep-text);
        border-radius: 6px;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }
    html.dark .badge-featured { background: var(--accent); color: var(--accent-contrast); }
    .badge-cat {
        font-size: 12px;
        font-weight: 600;
        color: var(--accent);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .featured-title {
        font-size: clamp(1.5rem, 3vw, 33px);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin-bottom: 16px;
        transition: color 0.2s;
    }
    .featured-card:hover .featured-title { color: var(--accent); }
    .featured-excerpt {
        font-size: 16px;
        color: var(--text-muted);
        line-height: 1.75;
        margin-bottom: 28px;
    }
    .featured-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .featured-meta { font-size: 13px; color: var(--text-dim); }
    .featured-card:hover .link-accent { color: var(--accent-hover); }

    /* ── Grid ── */
    .grid-wrap { max-width: 1180px; margin: 0 auto; padding: 24px 40px 96px; }
    @media (max-width: 640px) { .grid-wrap { padding: 24px 24px 64px; } }

    .post-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
        transition: opacity 0.18s ease, transform 0.18s ease;
    }
    .post-grid.changing { opacity: 0; transform: translateY(6px); }
    @media (max-width: 900px) { .post-grid { grid-template-columns: 1fr; } }

    .post-card {
        display: block;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        text-decoration: none;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }
    .post-card.hidden { display: none; }
    .post-card:hover {
        border-color: #b8d3ef;
        box-shadow: var(--shadow-card-hover);
        transform: translateY(-3px);
    }
    html.dark .post-card:hover { border-color: var(--accent); }

    .post-media { aspect-ratio: 16/10; background: var(--media-bg); overflow: hidden; }
    .post-img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .post-body { padding: 24px 24px 26px; }

    .post-cat {
        display: inline-flex;
        background: var(--accent-soft);
        color: var(--accent);
        border-radius: 6px;
        padding: 4px 11px;
        margin-bottom: 14px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }
    .post-title {
        font-size: 19px; font-weight: 700;
        line-height: 1.32; margin-bottom: 10px;
        transition: color 0.2s;
    }
    .post-card:hover .post-title { color: var(--accent); }
    .post-excerpt {
        font-size: 14px; color: var(--text-muted);
        line-height: 1.65; margin-bottom: 18px;
        display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .post-meta { font-size: 12.5px; color: var(--text-dim); letter-spacing: 0.02em; }

    /* ── Empty ── */
    .empty-state {
        display: none;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 4rem 0;
        text-align: center;
    }
    .empty-state.visible { display: flex; }
    .empty-title {
        font-family: Syne, sans-serif;
        font-size: 1.125rem; font-weight: 700;
        color: var(--text);
    }
    .empty-sub { font-size: 0.9375rem; color: var(--text-muted); }

    /* ── Pagination ── */
    .pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.375rem;
        padding-top: 3rem;
        flex-wrap: wrap;
    }
    .page-btn {
        font-family: inherit;
        font-size: 0.8125rem;
        font-weight: 500;
        min-width: 36px; height: 36px;
        padding: 0 0.5rem;
        border-radius: 8px;
        cursor: pointer;
        background: var(--card-bg);
        color: var(--text-body);
        border: 1px solid var(--border-strong);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: border-color 0.2s, background 0.2s, color 0.2s;
        user-select: none;
    }
    .page-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
    .page-btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: var(--accent-contrast);
        font-weight: 600;
    }
    .page-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .page-ellipsis { font-size: 0.8125rem; color: var(--text-dim); padding: 0 0.25rem; }
</style>

<script>
    // A 3-up grid reads best in whole rows; 6 fills exactly two.
    const POSTS_PER_PAGE = 6;

    // `button.` matters: the "+N topik lain" chip shares .tag-btn for styling
    // but is a link to /tags, not a filter.
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('button.tag-btn');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.post-card'));
    const gridEl = document.getElementById('posts-grid')!;
    const featuredEl = document.getElementById('featured');
    const featuredSlug = featuredEl?.dataset.slug ?? null;
    const paginationEl = document.getElementById('pagination')!;
    const emptyEl = document.getElementById('empty-state')!;

    let currentTag = 'all';
    let currentPage = 1;

    // On "Semua" the newest post is already the featured card, so it is dropped
    // from the grid pool. Filtering hides the featured card and returns that
    // post to the pool, so it stays reachable under its own tags.
    function getPool(): HTMLElement[] {
        if (currentTag === 'all') {
            return cards.filter((c) => c.dataset.slug !== featuredSlug);
        }
        return cards.filter((c) =>
            (c.dataset.tags ?? '').split(',').includes(currentTag),
        );
    }

    function renderPage() {
        const showFeatured = currentTag === 'all';
        featuredEl?.classList.toggle('hidden', !showFeatured);

        const pool = getPool();
        const totalPages = Math.ceil(pool.length / POSTS_PER_PAGE);
        const start = (currentPage - 1) * POSTS_PER_PAGE;

        cards.forEach((c) => c.classList.add('hidden'));
        pool.slice(start, start + POSTS_PER_PAGE).forEach((c) => c.classList.remove('hidden'));

        emptyEl.classList.toggle('visible', pool.length === 0);
        renderPagination(totalPages);
    }

    function pageRange(current: number, total: number): (number | '...')[] {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        const pages: (number | '...')[] = [1];
        if (current > 3) pages.push('...');
        for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
            pages.push(i);
        }
        if (current < total - 2) pages.push('...');
        pages.push(total);
        return pages;
    }

    function renderPagination(totalPages: number) {
        if (totalPages <= 1) { paginationEl.innerHTML = ''; return; }

        const btns: string[] = [
            `<button class="page-btn" data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''} aria-label="Halaman sebelumnya">&#8592;</button>`,
        ];

        pageRange(currentPage, totalPages).forEach((p) => {
            btns.push(
                p === '...'
                    ? `<span class="page-ellipsis">…</span>`
                    : `<button class="page-btn ${p === currentPage ? 'active' : ''}" data-page="${p}" aria-label="Halaman ${p}" aria-current="${p === currentPage ? 'page' : 'false'}">${p}</button>`,
            );
        });

        btns.push(
            `<button class="page-btn" data-page="${currentPage + 1}" ${currentPage === totalPages ? 'disabled' : ''} aria-label="Halaman berikutnya">&#8594;</button>`,
        );

        paginationEl.innerHTML = btns.join('');
        paginationEl.querySelectorAll<HTMLButtonElement>('.page-btn:not([disabled])').forEach((btn) => {
            btn.addEventListener('click', () => {
                const next = parseInt(btn.dataset.page ?? '1');
                if (next !== currentPage) goToPage(next);
            });
        });
    }

    function goToPage(page: number) {
        currentPage = page;
        gridEl.classList.add('changing');
        setTimeout(() => {
            renderPage();
            gridEl.classList.remove('changing');
            window.scrollTo({
                top: gridEl.getBoundingClientRect().top + window.scrollY - 120,
                behavior: 'smooth',
            });
        }, 180);
    }

    filterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
            filterBtns.forEach((b) => b.classList.remove('active'));
            btn.classList.add('active');
            currentTag = btn.dataset.tag ?? 'all';
            currentPage = 1;
            gridEl.classList.add('changing');
            setTimeout(() => {
                renderPage();
                gridEl.classList.remove('changing');
            }, 180);
        });
    });

    renderPage();
</script>
