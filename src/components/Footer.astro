---
const today = new Date();
---

<footer
    class="w-full py-12 px-6 md:px-12 max-w-7xl mx-auto border-t border-gray-200 mt-12 md:mt-20"
>
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="text-gray-500 text-sm">
            &copy; {today.getFullYear()} Appsecmonarch. All rights reserved.
        </div>
        <div class="flex gap-6">
            <a
                href="#"
                class="text-gray-500 hover:text-primary transition-colors"
                >Twitter</a
            >
            <a
                href="#"
                class="text-gray-500 hover:text-primary transition-colors"
                >GitHub</a
            >
            <a
                href="#"
                class="text-gray-500 hover:text-primary transition-colors"
                >LinkedIn</a
            >
        </div>
    </div>
</footer>
