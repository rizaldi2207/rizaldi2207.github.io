---
const { pathname } = Astro.url;
const isActive = (href: string) => {
  return pathname === href || (href !== "/" && pathname.startsWith(href));
};
---

<header
  class="relative z-50 w-full py-8 md:py-12 px-6 md:px-12 max-w-7xl mx-auto flex items-center justify-between"
>
  <!-- Logo -->
  <a href="/" class="transition-opacity hover:opacity-80">
    <img
      src="/src/assets/7de08a09-f9d8-4bcd-a85a-83ac8f1fc138-removebg-preview.png"
      alt="Astro Blog"
      class="h-10 w-auto"
    />
  </a>

  <!-- Desktop Nav -->
  <nav class="hidden md:flex items-center gap-8">
    <a
      href="/blog"
      class={`text-base font-medium transition-colors ${
        isActive("/blog") ? "text-primary" : "text-gray-600 hover:text-primary"
      }`}
    >
      Blog
    </a>
    <a
      href="/about"
      class={`text-base font-medium transition-colors ${
        isActive("/about") ? "text-primary" : "text-gray-600 hover:text-primary"
      }`}
    >
      Tentang
    </a>
    <a
      href="#"
      class="bg-primary text-white px-5 py-2.5 rounded-md font-medium text-sm"
    >
      Hubungi Kami
    </a>
  </nav>

  <!-- Hamburger -->
  <button
    id="menuBtn"
    class="md:hidden text-primary"
    aria-label="Open menu"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="w-8 h-8"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
      />
    </svg>
  </button>
</header>

<!-- Overlay -->
<div
  id="overlay"
  class="fixed inset-0 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<!-- Slide Menu -->
<aside
  id="mobileMenu"
  class="fixed top-0 right-0 h-full w-72 bg-white shadow-xl transform translate-x-full transition-transform duration-300 md:hidden z-50"
>
  <div class="p-6 flex justify-between items-center">
    <span class="font-semibold text-lg">Menu</span>
    <button id="closeBtn" aria-label="Close menu">✕</button>
  </div>

  <nav class="flex flex-col gap-6 px-6">
    <a href="/" class={isActive("/") ? "text-primary font-semibold" : ""}>
      Blog
    </a>
    <a href="/about" class={isActive("/about") ? "text-primary font-semibold" : ""}>
      Tentang
    </a>
    <a href="#" class="text-primary font-semibold">
      Hubungi Kami
    </a>
  </nav>
</aside>

<script>
    const btn = document.getElementById("menuBtn")!;
    const menu = document.getElementById("mobileMenu")!;
    const overlay = document.getElementById("overlay")!;
    const closeBtn = document.getElementById("closeBtn")!;

    const openMenu = () => {
    menu.classList.remove("translate-x-full");
    overlay.classList.remove("opacity-0", "pointer-events-none");
    };

    const closeMenu = () => {
    menu.classList.add("translate-x-full");
    overlay.classList.add("opacity-0", "pointer-events-none");
    };

    btn.addEventListener("click", openMenu);
    closeBtn.addEventListener("click", closeMenu);
    overlay.addEventListener("click", closeMenu);
</script>
