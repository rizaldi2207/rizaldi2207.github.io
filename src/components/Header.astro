---
const { pathname } = Astro.url;
const isActive = (href: string) =>
    pathname === href || (href !== "/" && pathname.startsWith(href));

const navLinks = [
    { href: "/blog", label: "Blog" },
    { href: "/about", label: "Tentang" },
];
---

<header id="site-header" class="site-header">
    <div class="header-inner">
        <!-- Logo -->
        <a href="/" class="logo-link">
            <img
                src="/assets/7de08a09-f9d8-4bcd-a85a-83ac8f1fc138-removebg-preview.png"
                alt="Appsecmonarch"
                class="logo-img"
            />
        </a>

        <!-- Desktop Nav -->
        <nav class="desktop-nav">
            {navLinks.map(({ href, label }) => (
                <a href={href} class={`nav-link ${isActive(href) ? "nav-active" : ""}`}>
                    {label}
                    {isActive(href) && <span class="nav-underline" />}
                </a>
            ))}

            <!-- Dark mode toggle -->
            <button id="themeToggle" class="theme-toggle" aria-label="Toggle dark mode">
                <span class="theme-thumb">
                    <span id="themeIcon" class="theme-icon">☀️</span>
                </span>
            </button>

            <a href="/contact" class="contact-btn">Hubungi Kami</a>
        </nav>

        <!-- Hamburger -->
        <button id="menuBtn" class="hamburger-btn" aria-label="Open menu">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
        </button>
    </div>
</header>

<!-- Mobile overlay -->
<div id="overlay" class="mobile-overlay"></div>

<!-- Mobile slide menu -->
<aside id="mobileMenu" class="mobile-menu">
    <div class="mobile-menu-header">
        <span class="mobile-menu-title">Menu</span>
        <div style="display:flex;align-items:center;gap:0.75rem;">
            <button id="themeMobileToggle" class="theme-toggle" aria-label="Toggle dark mode">
                <span class="theme-thumb">
                    <span id="themeMobileIcon" class="theme-icon">☀️</span>
                </span>
            </button>
            <button id="closeBtn" class="close-btn" aria-label="Close menu">✕</button>
        </div>
    </div>
    <nav class="mobile-nav">
        {navLinks.map(({ href, label }) => (
            <a href={href} class="mobile-nav-link">{label}</a>
        ))}
        <a href="/contact" class="mobile-nav-link mobile-nav-cta">Hubungi Kami</a>
    </nav>
</aside>

<style>
    .site-header {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        background: transparent;
        transition: background 0.3s ease, backdrop-filter 0.3s ease, border-bottom 0.3s ease;
    }
    .site-header.scrolled {
        background: var(--header-bg-scroll);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0, 212, 255, 0.08);
    }
    html:not(.dark) .site-header.scrolled {
        border-bottom-color: rgba(0, 51, 119, 0.08);
    }

    .header-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 1.25rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .logo-link { transition: opacity 0.2s; }
    .logo-link:hover { opacity: 0.8; }
    .logo-img {
        height: 40px; width: auto;
        filter: none;
        transition: filter 0.3s;
    }
    html.dark .logo-img { filter: brightness(1.25); }

    .desktop-nav {
        display: none;
        align-items: center;
        gap: 2rem;
    }
    @media (min-width: 768px) { .desktop-nav { display: flex; } }

    .nav-link {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
        position: relative;
    }
    .nav-link:hover { color: #00d4ff; }
    html:not(.dark) .nav-link:hover { color: #003377; }
    .nav-link.nav-active { color: #00d4ff; }
    html:not(.dark) .nav-link.nav-active { color: #003377; }

    .nav-underline {
        position: absolute;
        bottom: -4px; left: 0; right: 0;
        height: 2px;
        background: #00d4ff;
        border-radius: 2px;
        transform-origin: left;
        animation: slideIn 0.2s ease;
    }
    html:not(.dark) .nav-underline { background: #003377; }

    .theme-toggle {
        width: 48px; height: 26px;
        border-radius: 13px;
        background: rgba(0, 212, 255, 0.15);
        border: none; cursor: pointer;
        padding: 3px;
        display: flex; align-items: center;
        transition: background 0.3s ease;
        flex-shrink: 0;
    }
    html.dark .theme-toggle { background: #00d4ff; }

    .theme-thumb {
        width: 20px; height: 20px;
        border-radius: 50%;
        background: #fff;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 1px 4px rgba(0,0,0,0.2);
        transform: translateX(0);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    html.dark .theme-thumb { transform: translateX(22px); }

    .theme-icon { font-size: 0.65rem; line-height: 1; }

    .contact-btn {
        background: #003377;
        color: #fff !important;
        padding: 0.6rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        transition: opacity 0.2s;
        letter-spacing: 0.01em;
    }
    html.dark .contact-btn { background: #00d4ff; color: #0a0e1a !important; }
    .contact-btn:hover { opacity: 0.88; }

    .hamburger-btn {
        display: flex;
        background: none; border: none; cursor: pointer;
        color: var(--text);
    }
    @media (min-width: 768px) { .hamburger-btn { display: none; } }

    .mobile-overlay {
        position: fixed; inset: 0;
        background: rgba(0, 0, 0, 0.5);
        opacity: 0; pointer-events: none;
        transition: opacity 0.3s;
        z-index: 110;
    }
    .mobile-overlay.open { opacity: 1; pointer-events: auto; }

    .mobile-menu {
        position: fixed; top: 0; right: 0;
        height: 100%; width: 18rem;
        background: var(--card-bg);
        box-shadow: -4px 0 24px rgba(0,0,0,0.15);
        transform: translateX(100%);
        transition: transform 0.3s ease;
        z-index: 120;
    }
    .mobile-menu.open { transform: translateX(0); }

    .mobile-menu-header {
        padding: 1.25rem 1.5rem;
        display: flex; align-items: center; justify-content: space-between;
        border-bottom: 1px solid var(--border);
    }
    .mobile-menu-title {
        font-weight: 600; font-size: 1.0625rem;
        color: var(--text);
    }

    .close-btn {
        background: none; border: none; cursor: pointer;
        font-size: 1.125rem; color: var(--text-muted);
    }

    .mobile-nav {
        display: flex; flex-direction: column;
        padding: 1rem 1.5rem 1.5rem;
        gap: 0;
    }
    .mobile-nav-link {
        display: block;
        padding: 0.875rem 0;
        font-weight: 500; font-size: 1rem;
        color: var(--text);
        text-decoration: none;
        border-bottom: 1px solid var(--border);
        transition: color 0.2s;
    }
    .mobile-nav-link:hover { color: #00d4ff; }
    html:not(.dark) .mobile-nav-link:hover { color: #003377; }
    .mobile-nav-cta {
        margin-top: 1rem;
        border: none;
        background: #003377; color: #fff !important;
        border-radius: 8px; padding: 0.75rem 1.5rem;
        font-weight: 600; text-align: center;
    }
    html.dark .mobile-nav-cta { background: #00d4ff; color: #0a0e1a !important; }
</style>

<script>
    function updateThemeIcons(isDark) {
        const icon = document.getElementById('themeIcon');
        const mobileIcon = document.getElementById('themeMobileIcon');
        const emoji = isDark ? '🌙' : '☀️';
        if (icon) icon.textContent = emoji;
        if (mobileIcon) mobileIcon.textContent = emoji;
    }

    function toggleTheme() {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateThemeIcons(isDark);
    }

    // Init icons
    updateThemeIcons(document.documentElement.classList.contains('dark'));

    document.getElementById('themeToggle')?.addEventListener('click', toggleTheme);
    document.getElementById('themeMobileToggle')?.addEventListener('click', toggleTheme);

    // Scroll blur
    const header = document.getElementById('site-header');
    if (header) {
        window.addEventListener('scroll', () => {
            header.classList.toggle('scrolled', window.scrollY > 20);
        });
    }

    // Mobile menu
    const menuBtn = document.getElementById('menuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const overlay = document.getElementById('overlay');
    const closeBtn = document.getElementById('closeBtn');

    function openMenu() {
        mobileMenu?.classList.add('open');
        overlay?.classList.add('open');
    }
    function closeMenu() {
        mobileMenu?.classList.remove('open');
        overlay?.classList.remove('open');
    }

    menuBtn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    overlay?.addEventListener('click', closeMenu);
</script>
