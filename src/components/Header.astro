---
const { pathname } = Astro.url;
const isActive = (href: string) => {
    return pathname === href || (href !== "/" && pathname.startsWith(href));
};
---

<header
    class="w-full py-8 md:py-12 px-6 md:px-12 max-w-7xl mx-auto flex items-center justify-between"
>
    <a
        href="/"
        class="text-primary font-serif font-bold text-2xl tracking-tight hover:text-primary-hover transition-colors"
    >
        Astro Blog
    </a>

    <nav class="hidden md:flex items-center gap-8">
        <a
            href="/"
            class={`text-base font-medium transition-colors ${isActive("/") ? "text-primary" : "text-gray-600 hover:text-primary"}`}
        >
            Blog
        </a>
        <a
            href="/about"
            class={`text-base font-medium transition-colors ${isActive("/about") ? "text-primary" : "text-gray-600 hover:text-primary"}`}
        >
            Tentang
        </a>
        <a
            href="#"
            class="bg-primary text-white px-5 py-2.5 rounded-md font-medium text-sm hover:bg-primary-hover transition-colors"
        >
            Hubungi Kami
            <span
                class="inline-block border-b-2 border-white/30 w-full h-[1px] absolute bottom-1 left-0 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"
            ></span>
        </a>
    </nav>

    <button class="md:hidden text-primary">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-8 h-8"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
    </button>
</header>
