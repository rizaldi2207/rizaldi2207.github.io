---
const { pathname } = Astro.url;
const isActive = (href: string) =>
    href === "/" ? pathname === "/" : pathname.startsWith(href);

const navLinks = [
    { href: "/", label: "Beranda" },
    { href: "/blog", label: "Blog" },
    { href: "/about", label: "Tentang" },
    { href: "/contact", label: "Hubungi" },
];
---

<header id="site-header" class="site-header">
    <div class="header-inner">
        <a href="/" class="brand">
            {/* Both marks ship; CSS picks one per theme. Swapping the `src` in
                JS instead would flash the wrong mark before the script runs. */}
            <img src="/assets/logo.png" alt="" class="brand-mark brand-mark-light" aria-hidden="true" />
            <img src="/assets/logo-white.png" alt="" class="brand-mark brand-mark-dark" aria-hidden="true" />
            <span class="brand-text">
                <span class="brand-name">appsecmonarch</span>
                <span class="brand-tagline">learn · share · secure</span>
            </span>
        </a>

        <nav class="desktop-nav" aria-label="Navigasi utama">
            {navLinks.map(({ href, label }) => (
                <a
                    href={href}
                    class={`nav-link ${isActive(href) ? "nav-active" : ""}`}
                    aria-current={isActive(href) ? "page" : undefined}
                >
                    {label}
                    {isActive(href) && <span class="nav-underline" />}
                </a>
            ))}

            <button id="themeToggle" class="theme-toggle" aria-label="Ganti tema gelap/terang">
                <span class="theme-thumb"><span id="themeIcon" class="theme-icon">☀️</span></span>
            </button>

            <a href="/contact" class="cta-btn">Konsultasi</a>
        </nav>

        <button id="menuBtn" class="hamburger-btn" aria-label="Buka menu">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
        </button>
    </div>
</header>

<div id="overlay" class="mobile-overlay"></div>

<aside id="mobileMenu" class="mobile-menu" aria-label="Menu">
    <div class="mobile-menu-header">
        <span class="mobile-menu-title">Menu</span>
        <div class="mobile-menu-actions">
            <button id="themeMobileToggle" class="theme-toggle" aria-label="Ganti tema gelap/terang">
                <span class="theme-thumb"><span id="themeMobileIcon" class="theme-icon">☀️</span></span>
            </button>
            <button id="closeBtn" class="close-btn" aria-label="Tutup menu">✕</button>
        </div>
    </div>
    <nav class="mobile-nav">
        {navLinks.map(({ href, label }) => (
            <a href={href} class="mobile-nav-link">{label}</a>
        ))}
        <a href="/contact" class="mobile-nav-cta">Konsultasi</a>
    </nav>
</aside>

<style>
    /* Sticky, not fixed — the design's nav occupies layout space, so no
       compensating top padding is needed on <main>. */
    .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--header-bg-scroll);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        transition: border-color 0.3s ease;
    }

    .header-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 40px;
        height: 74px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    @media (max-width: 640px) { .header-inner { padding: 0 24px; } }

    /* ── Brand ── */
    .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .brand-mark { width: 36px; height: 33px; object-fit: contain; flex-shrink: 0; }

    /* The full-colour mark is half dark navy (#013378), which sits at ~1.45:1
       against the navy header — the shape dissolves. On navy the brand uses its
       white mark instead; the design does the same in the footer. */
    .brand-mark-dark { display: none; }
    html.dark .brand-mark-light { display: none; }
    html.dark .brand-mark-dark { display: block; }
    .brand-text { display: flex; flex-direction: column; }
    .brand-name {
        font-family: Syne, sans-serif;
        font-size: 21px;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.02em;
        line-height: 1;
    }
    .brand-tagline {
        font-size: 9px;
        font-weight: 600;
        color: var(--accent);
        letter-spacing: 0.22em;
        text-transform: uppercase;
        margin-top: 3px;
    }

    /* ── Desktop nav ── */
    .desktop-nav { display: none; align-items: center; gap: 34px; }
    @media (min-width: 900px) { .desktop-nav { display: flex; } }

    .nav-link {
        position: relative;
        font-size: 15px;
        font-weight: 500;
        color: var(--text);
        text-decoration: none;
        padding: 6px 0;
        transition: color 0.2s;
    }
    .nav-link:hover { color: var(--accent); }
    .nav-link.nav-active { color: var(--accent); }

    .nav-underline {
        position: absolute;
        left: 0; right: 0; bottom: -4px;
        height: 2px;
        background: var(--accent);
        border-radius: 2px;
        transform-origin: left;
        animation: slideIn 0.2s ease;
    }

    /* ── Theme toggle ── */
    .theme-toggle {
        width: 48px; height: 26px;
        border-radius: 13px;
        background: var(--accent-soft);
        border: 1px solid var(--border-strong);
        cursor: pointer;
        padding: 3px;
        display: flex; align-items: center;
        transition: background 0.3s ease;
        flex-shrink: 0;
    }
    html.dark .theme-toggle { background: var(--accent); border-color: transparent; }

    .theme-thumb {
        width: 18px; height: 18px;
        border-radius: 50%;
        background: #fff;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 1px 4px rgba(0, 24, 64, 0.2);
        transform: translateX(0);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    html.dark .theme-thumb { transform: translateX(22px); }
    .theme-icon { font-size: 0.6rem; line-height: 1; }

    /* ── CTA ── */
    .cta-btn {
        background: var(--accent);
        color: var(--accent-contrast);
        font-size: 14px;
        font-weight: 600;
        padding: 11px 22px;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.2s;
    }
    .cta-btn:hover { background: var(--accent-hover); }

    /* ── Hamburger ── */
    .hamburger-btn {
        display: flex;
        background: none; border: none; cursor: pointer;
        color: var(--text);
        padding: 0;
    }
    @media (min-width: 900px) { .hamburger-btn { display: none; } }

    /* ── Mobile menu ── */
    .mobile-overlay {
        position: fixed; inset: 0;
        background: rgba(0, 24, 64, 0.5);
        opacity: 0; pointer-events: none;
        transition: opacity 0.3s;
        z-index: 110;
    }
    .mobile-overlay.open { opacity: 1; pointer-events: auto; }

    .mobile-menu {
        position: fixed; top: 0; right: 0;
        height: 100%; width: 18rem;
        background: var(--card-bg);
        border-left: 1px solid var(--border);
        box-shadow: -4px 0 24px rgba(0, 24, 64, 0.15);
        transform: translateX(100%);
        transition: transform 0.3s ease;
        z-index: 120;
    }
    .mobile-menu.open { transform: translateX(0); }

    .mobile-menu-header {
        padding: 1.25rem 1.5rem;
        display: flex; align-items: center; justify-content: space-between;
        border-bottom: 1px solid var(--border);
    }
    .mobile-menu-title {
        font-family: Syne, sans-serif;
        font-weight: 700; font-size: 1.0625rem;
        color: var(--text);
    }
    .mobile-menu-actions { display: flex; align-items: center; gap: 0.75rem; }

    .close-btn {
        background: none; border: none; cursor: pointer;
        font-size: 1.125rem; color: var(--text-muted);
    }

    .mobile-nav { display: flex; flex-direction: column; padding: 1rem 1.5rem 1.5rem; }
    .mobile-nav-link {
        padding: 0.875rem 0;
        font-weight: 500; font-size: 1rem;
        color: var(--text);
        text-decoration: none;
        border-bottom: 1px solid var(--border);
        transition: color 0.2s;
    }
    .mobile-nav-link:hover { color: var(--accent); }

    .mobile-nav-cta {
        margin-top: 1rem;
        background: var(--accent);
        color: var(--accent-contrast);
        border-radius: 8px;
        padding: 0.75rem 1.5rem;
        font-weight: 600; font-size: 0.9375rem;
        text-align: center;
        text-decoration: none;
        transition: background 0.2s;
    }
    .mobile-nav-cta:hover { background: var(--accent-hover); }
</style>

<script>
    function updateThemeIcons(isDark: boolean) {
        const emoji = isDark ? '🌙' : '☀️';
        const icon = document.getElementById('themeIcon');
        const mobileIcon = document.getElementById('themeMobileIcon');
        if (icon) icon.textContent = emoji;
        if (mobileIcon) mobileIcon.textContent = emoji;
    }

    function toggleTheme() {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateThemeIcons(isDark);
    }

    updateThemeIcons(document.documentElement.classList.contains('dark'));

    document.getElementById('themeToggle')?.addEventListener('click', toggleTheme);
    document.getElementById('themeMobileToggle')?.addEventListener('click', toggleTheme);

    const mobileMenu = document.getElementById('mobileMenu');
    const overlay = document.getElementById('overlay');

    function openMenu() {
        mobileMenu?.classList.add('open');
        overlay?.classList.add('open');
    }
    function closeMenu() {
        mobileMenu?.classList.remove('open');
        overlay?.classList.remove('open');
    }

    document.getElementById('menuBtn')?.addEventListener('click', openMenu);
    document.getElementById('closeBtn')?.addEventListener('click', closeMenu);
    overlay?.addEventListener('click', closeMenu);
</script>
