---
interface Props {
    title: string;
    description: string;
    pubDate: Date;
    image: string;
    slug: string;
    tags?: string[];
}

const { title, description, pubDate, image, slug, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("id-ID", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<article class="group flex flex-col bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
    <a href={`/blog/${slug}`} class="block aspect-[16/9] overflow-hidden bg-gray-100">
        <img
            src={image}
            alt={title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
    </a>

    <div class="p-6 flex flex-col flex-1">
        <div class="flex flex-wrap gap-2 mb-3">
            {
                tags.map((tag) => (
                    <a 
                        href={`/tags/${tag}`}
                        class="text-primary font-serif italic text-sm hover:underline"
                    >
                        #{tag}
                    </a>
                ))
            }
        </div>

        <h3 class="text-xl md:text-2xl font-serif font-bold text-gray-900 mb-3 leading-tight group-hover:text-primary transition-colors">
            <a href={`/blog/${slug}`}>
                {title}
            </a>
        </h3>

        <p class="text-gray-600 mb-4 line-clamp-2 leading-relaxed flex-1">
            {description}
        </p>

        <div class="text-sm text-gray-500 font-medium">
            {formattedDate}
        </div>
    </div>
</article>
