---
interface Props {
    title: string;
    description: string;
    pubDate: Date;
    image: string;
    slug: string;
    tags?: string[];
}

const { title, description, pubDate, image, slug, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("id-ID", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<article
    class="group relative flex flex-col md:flex-row gap-6 md:gap-10 items-start py-8 md:py-12 border-b border-gray-200 last:border-0"
>
    <a
        href={`/blog/${slug}`}
        class="w-full md:w-5/12 aspect-[4/3] overflow-hidden rounded-lg bg-gray-100 block shrink-0"
    >
        <img
            src={image}
            alt={title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
    </a>

    <div class="flex-1 flex flex-col h-full justify-center">
        <div class="flex flex-wrap gap-2 mb-3">
            {
                tags.map((tag) => (
                    <span class="text-primary font-serif italic text-sm">
                        #{tag}
                    </span>
                ))
            }
        </div>

        <h2
            class="text-2xl md:text-3xl font-serif font-bold text-gray-900 mb-3 leading-tight group-hover:text-primary transition-colors"
        >
            <a href={`/blog/${slug}`}>
                {title}
            </a>
        </h2>

        <p class="text-gray-600 mb-4 line-clamp-3 leading-relaxed">
            {description}
        </p>

        <div class="mt-auto text-sm text-gray-500 font-medium">
            {formattedDate}
        </div>
    </div>
</article>
